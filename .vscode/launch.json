{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CliGJ VSCode Extension (Extension Host)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}\\vscode-extension"
      ],
      "outFiles": [
        "${workspaceFolder}\\vscode-extension\\dist\\**\\*.js"
      ]
    },
    {
      "name": "CliGJ (debug exe, CodeLLDB)",
      "type": "lldb",
      "request": "launch",
      "preLaunchTask": "cargo: build (debug)",
      "program": "${workspaceFolder}\\target\\debug\\CliGJ.exe",
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_BACKTRACE": "1",
        "RUST_LOG": "debug",
        "SLINT_DEBUG_PERFORMANCE_OVERLAY": "1"
      }
    },
    {
      "name": "CliGJ (cargo run, no debugger)",
      "type": "pwa-node",
      "request": "launch",
      "runtimeExecutable": "cargo",
      "runtimeArgs": ["run"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "RUST_BACKTRACE": "1",
        "RUST_LOG": "debug",
        "SLINT_DEBUG_PERFORMANCE_OVERLAY": "1"
      }
    }
  ]
}

