{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cargo: build (debug)",
      "type": "shell",
      "command": "cargo",
      "args": ["build"],
      "group": "build",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo: check",
      "type": "shell",
      "command": "cargo",
      "args": ["check"],
      "group": "build",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo: run (debug env)",
      "type": "shell",
      "command": "cargo",
      "args": ["run"],
      "group": "test",
      "problemMatcher": ["$rustc"],
      "options": {
        "env": {
          "RUST_BACKTRACE": "1",
          "RUST_LOG": "debug",
          "SLINT_DEBUG_PERFORMANCE_OVERLAY": "1"
        }
      }
    }
  ]
}

