// Shared types for ANSI-colored terminal emulation (wezterm-term → UI).

export struct TermSpan {
    text: string,
    fg: color,
    bg: color,
    font-family: string,
}

/// One attached image in the composer (thumbnail + label; path is kept in Rust for submit).
export struct PromptImageChip {
    label: string,
    thumb: image,
}

/// One row in the interactive-command editor (launcher name + shell command).
export struct InteractiveCmdEditorRow {
    name: string,
    line: string,
    /// Whether this command should use the InteractiveAi terminal path.
    interactive-cli: bool,
    /// Interactive launcher only: keep the last N terminal rows fixed at the bottom. `0` disables.
    pinned-footer-lines: string,
    /// Interactive launcher only: comma-separated visible text markers that identify the CLI screen.
    markers: string,
    /// Interactive launcher only: archive repaint-only TUI frames as GUI-side history.
    archive-repainted-frames: bool,
    /// Built-in preset rows: key label is read-only; name is still carried for display.
    key-locked: bool,
    expanded: bool,
    /// Shell profile: 自訂工作區根目錄；空白則使用分頁／啟動目錄。
    workspace-path: string,
}

export struct TermLine {
    // True when the PTY physical row has no visible cells (no fake row height in the viewer).
    blank: bool,
    /// Total Unicode scalar count across spans (for monospace column hit-testing).
    char-count: int,
    spans: [TermSpan],
}
