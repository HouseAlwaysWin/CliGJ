import { AppTheme } from "../theme.slint";
import { InteractiveCmdEditorRow } from "../term_types.slint";
import { GjChromeButton } from "../components/gj_chrome_button.slint";
import { LineEdit, ScrollView } from "std-widgets.slint";

export component GjInteractiveManageDialog inherits Rectangle {
    // Avoid `100%` / `parent.width` here: Slint cannot resolve them when this file is analyzed alone
    // (LSP: "Cannot find parent property to apply relative length"). Real size comes from `app.slint`.
    preferred-width: 800px;
    preferred-height: 600px;
    background: #00000080;
    z: 106;

    in-out property <[InteractiveCmdEditorRow]> manage-rows;

    callback manage-add-row;
    callback remove-row(int);
    callback name-edited(int, string);
    callback line-edited(int, string);
    callback interactive-cli-toggled(int);
    callback pinned-lines-edited(int, string);
    callback markers-edited(int, string);
    callback archive-repainted-toggled(int);
    callback save;
    callback close;
    callback restore-defaults;

    VerticalLayout {
        horizontal-stretch: 1;
        vertical-stretch: 1;
        padding: 12px;
        spacing: 0px;

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: AppTheme.panel;
            border-width: 1px;
            border-color: AppTheme.prompt_chrome_border;
            border-radius: 10px;

            VerticalLayout {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                padding: 12px;
                spacing: 8px;

            Text {
                text: @tr("指令設定");
                color: AppTheme.text;
                font-size: 13px;
                font-weight: 600;
            }

            Text {
                text: @tr("變更後請按「儲存」寫入設定；「回復預設」可還原內建 Gemini / Codex / Claude / Copilot。");
                color: AppTheme.text_muted;
                font-size: 11px;
                wrap: word-wrap;
            }

            Text {
                text: "Interactive decides whether the command uses the InteractiveAi terminal path. Markers identify CLI screens; Replay saves repaint-only TUI history.";
                color: AppTheme.text_muted;
                font-size: 11px;
                wrap: word-wrap;
            }

            HorizontalLayout {
                spacing: 8px;
                alignment: start;

                GjChromeButton {
                    label: @tr("新增");
                    min-button-width: 64px;
                    preset: "add";
                    clicked => {
                        root.manage-add-row();
                    }
                }

                GjChromeButton {
                    label: @tr("回復預設");
                    min-button-width: 88px;
                    preset: "restore";
                    clicked => {
                        root.restore-defaults();
                    }
                }

                GjChromeButton {
                    label: @tr("關閉");
                    min-button-width: 72px;
                    preset: "close";
                    clicked => {
                        root.close();
                    }
                }

                GjChromeButton {
                    label: @tr("儲存");
                    min-button-width: 72px;
                    preset: "save";
                    clicked => {
                        root.save();
                    }
                }
            }

            ScrollView {
                vertical-stretch: 1;
                min-height: 0px;

                VerticalLayout {
                    alignment: start;
                    spacing: 6px;

                    for row[key_idx] in root.manage-rows: Rectangle {
                        min-height: 104px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 6px;
                        background: #00000000;

                        VerticalLayout {
                            padding-left: 6px;
                            padding-right: 6px;
                            padding-top: 6px;
                            padding-bottom: 6px;
                            spacing: 6px;

                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;

                                VerticalLayout {
                                    min-width: 100px;
                                    max-width: 100px;
                                    horizontal-stretch: 0;
                                    vertical-stretch: 1;
                                    alignment: center;
                                    spacing: 4px;

                                    if row.key-locked: Rectangle {
                                        horizontal-stretch: 1;
                                        min-height: 26px;
                                        background: #00000020;
                                        border-radius: 4px;

                                        Text {
                                            text: row.name;
                                            color: AppTheme.text_muted;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                            horizontal-alignment: left;
                                            overflow: elide;
                                        }
                                    }

                                    if !row.key-locked: LineEdit {
                                        horizontal-stretch: 1;
                                        min-height: 26px;
                                        font-size: 12px;
                                        text: row.name;
                                        edited(new_text) => {
                                            root.name-edited(key_idx, new_text);
                                        }
                                    }
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 6px;

                                    HorizontalLayout {
                                        spacing: 8px;
                                        alignment: start;

                                        Rectangle {
                                            horizontal-stretch: 0;
                                            min-width: 76px;
                                            max-width: 76px;
                                            min-height: 26px;
                                            background: #00000000;

                                            Text {
                                                text: @tr("指令");
                                                color: AppTheme.text_muted;
                                                font-size: 11px;
                                                vertical-alignment: center;
                                                horizontal-alignment: left;
                                            }
                                        }

                                        LineEdit {
                                            horizontal-stretch: 1;
                                            min-height: 26px;
                                            font-size: 12px;
                                            text: row.line;
                                            edited(new_text) => {
                                                root.line-edited(key_idx, new_text);
                                            }
                                        }
                                    }

                                    HorizontalLayout {
                                        spacing: 8px;
                                        alignment: start;

                                        Rectangle {
                                            horizontal-stretch: 0;
                                            min-width: 76px;
                                            max-width: 76px;
                                            min-height: 26px;
                                            background: #00000000;

                                            Text {
                                                text: @tr("Markers");
                                                color: AppTheme.text_muted;
                                                font-size: 11px;
                                                vertical-alignment: center;
                                                horizontal-alignment: left;
                                            }
                                        }

                                        LineEdit {
                                            horizontal-stretch: 1;
                                            min-height: 26px;
                                            font-size: 12px;
                                            text: row.markers;
                                            edited(new_text) => {
                                                root.markers-edited(key_idx, new_text);
                                            }
                                        }
                                    }

                                    HorizontalLayout {
                                        spacing: 8px;
                                        alignment: start;

                                        Rectangle {
                                            width: 28px;
                                            height: 26px;
                                            horizontal-stretch: 0;
                                            border-width: 1px;
                                            border-color: AppTheme.prompt_chrome_border;
                                            border-radius: 6px;
                                            background: #00000000;

                                            Image {
                                                width: 14px;
                                                height: 14px;
                                                x: (parent.width - self.width) / 2;
                                                y: (parent.height - self.height) / 2;
                                                source: @image-url("../icons/prompt_pin.svg");
                                                colorize: AppTheme.text_muted;
                                            }
                                        }

                                        LineEdit {
                                            horizontal-stretch: 0;
                                            min-width: 52px;
                                            max-width: 72px;
                                            min-height: 26px;
                                            font-size: 12px;
                                            text: row.pinned-footer-lines;
                                            edited(new_text) => {
                                                root.pinned-lines-edited(key_idx, new_text);
                                            }
                                        }

                                        Rectangle {
                                            horizontal-stretch: 1;
                                            min-height: 1px;
                                            background: #00000000;
                                        }

                                        GjChromeButton {
                                            label: "Interactive";
                                            min-button-width: 82px;
                                            max-button-width: 92px;
                                            button-height: 24px;
                                            pill-corner-radius: 6px;
                                            label-font-size: 11px;
                                            preset: "toggle-accent";
                                            active: row.interactive-cli;
                                            clicked => {
                                                root.interactive-cli-toggled(key_idx);
                                            }
                                        }

                                        GjChromeButton {
                                            label: "Replay";
                                            min-button-width: 62px;
                                            max-button-width: 72px;
                                            button-height: 24px;
                                            pill-corner-radius: 6px;
                                            label-font-size: 11px;
                                            preset: "toggle-accent";
                                            active: row.archive-repainted-frames;
                                            clicked => {
                                                root.archive-repainted-toggled(key_idx);
                                            }
                                        }

                                        GjChromeButton {
                                            label: @tr("刪除");
                                            min-button-width: 44px;
                                            max-button-width: 52px;
                                            button-height: 24px;
                                            pill-corner-radius: 6px;
                                            label-font-size: 11px;
                                            preset: "danger";
                                            clicked => {
                                                root.remove-row(key_idx);
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
            }
        }
    }
}
