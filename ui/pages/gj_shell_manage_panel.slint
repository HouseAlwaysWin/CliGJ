import { AppTheme } from "../theme.slint";
import { InteractiveCmdEditorRow } from "../term_types.slint";
import { GjChromeButton } from "../components/gj_chrome_button.slint";
import { ComboBox, LineEdit, ScrollView } from "std-widgets.slint";

/// Full-window shell settings: startup defaults + command profile editor.
export component GjShellManagePanel inherits Rectangle {
    // Avoid relative `%` sizing in standalone component analysis; real size is set by `app.slint`.
    preferred-width: 800px;
    preferred-height: 600px;
    background: AppTheme.bg;
    z: 107;

    in-out property <string> settings-nav;
    in-out property <string> startup-default-profile;
    in-out property <string> startup-language;
    in-out property <string> startup-ui-zoom;
    in-out property <string> startup-terminal-font-family;
    in-out property <string> startup-terminal-cjk-fallback-font-family;
    in property <[string]> cmd-type-choices;
    in property <[string]> startup-language-choices;
    in property <[string]> startup-ui-zoom-choices;
    in property <[string]> startup-terminal-font-choices;
    in property <[string]> startup-terminal-cjk-fallback-font-choices;
    in-out property <[InteractiveCmdEditorRow]> shell-manage-rows;
    in-out property <bool> manage-saved-hint;

    callback close-requested;
    callback add-shell-row;
    callback remove-shell-row(int);
    callback shell-name-edited(int, string);
    callback shell-line-edited(int, string);
    callback shell-workspace-edited(int, string);
    callback shell-workspace-pick-folder(int);
    callback save-shell-manage;
    callback save-startup-settings;
    callback toggle-row-expanded(int);
    /// Fired when the startup language ComboBox changes (immediate UI language switch).
    callback shell-ui-language-changed(string);
    callback shell-ui-zoom-changed(string);

    HorizontalLayout {
        spacing: 0px;

        Rectangle {
            width: 196px;
            vertical-stretch: 1;
            background: AppTheme.panel;
            border-width: 0px;

            VerticalLayout {
                padding: 10px;
                spacing: 8px;

                GjChromeButton {
                    label: @tr("返回");
                    min-button-width: 64px;
                    button-height: 28px;
                    preset: "close";
                    clicked => {
                        root.close-requested();
                    }
                }

                Rectangle {
                    height: 1px;
                    background: AppTheme.prompt_chrome_border;
                }

                Rectangle {
                    height: 30px;
                    border-radius: 6px;
                    background: root.settings-nav == "startup"
                        ? #2d2d30
                        : (startup_nav_ta.has-hover ? #2a2a32 : #00000000);

                    Text {
                        text: @tr("啟動");
                        color: root.settings-nav == "startup" ? AppTheme.text : AppTheme.text_muted;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                        width: 100%;
                        font-size: 12px * AppTheme.ui_zoom_factor;
                        overflow: elide;
                    }

                    startup_nav_ta := TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => {
                            root.settings-nav = "startup";
                            root.manage-saved-hint = false;
                        }
                    }
                }

                Rectangle {
                    height: 30px;
                    border-radius: 6px;
                    background: root.settings-nav == "shell_cmds"
                        ? #2d2d30
                        : (shell_cmds_nav_ta.has-hover ? #2a2a32 : #00000000);

                    Text {
                        text: @tr("命令提示設定");
                        color: root.settings-nav == "shell_cmds" ? AppTheme.text : AppTheme.text_muted;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                        width: 100%;
                        font-size: 12px * AppTheme.ui_zoom_factor;
                        overflow: elide;
                    }

                    shell_cmds_nav_ta := TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => {
                            root.settings-nav = "shell_cmds";
                            root.manage-saved-hint = false;
                        }
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                    background: #00000000;
                }
            }
        }

        Rectangle {
            width: 1px;
            vertical-stretch: 1;
            background: AppTheme.prompt_chrome_border;
        }

        Rectangle {
            vertical-stretch: 1;
            horizontal-stretch: 1;
            background: AppTheme.bg;

            VerticalLayout {
                padding: 12px;
                spacing: 8px;

                Text {
                    text: root.settings-nav == "startup"
                        ? @tr("設定 / 啟動")
                        : @tr("設定 / 命令提示設定");
                    color: AppTheme.text;
                    font-size: 13px * AppTheme.ui_zoom_factor;
                    font-weight: 600;
                }

                if root.settings-nav == "startup": VerticalLayout {
                    spacing: 10px;
                    vertical-stretch: 1;

                    Text {
                        text: @tr("設定新分頁預設啟動行為。");
                        color: AppTheme.text_muted;
                        font-size: 11px * AppTheme.ui_zoom_factor;
                        wrap: word-wrap;
                    }

                    Rectangle {
                        height: 42px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 6px;
                        background: #00000000;

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 10px;
                            alignment: center;

                            Rectangle {
                                width: 140px;
                                horizontal-stretch: 0;
                                height: parent.height;

                                Text {
                                    width: 100%;
                                    height: 100%;
                                    text: @tr("預設設定檔");
                                    color: AppTheme.text_muted;
                                    font-size: 12px * AppTheme.ui_zoom_factor;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                background: #00000000;
                            }

                            Rectangle {
                                width: 240px;
                                horizontal-stretch: 0;
                                background: #00000000;

                                ComboBox {
                                    width: 100%;
                                    model: root.cmd-type-choices;
                                    current-value <=> root.startup-default-profile;
                                    selected(val) => {
                                        root.startup-default-profile = val;
                                        self.current-value = val;
                                    }
                                }
                            }
                        }
                    }

                    Rectangle {
                        height: 42px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 6px;
                        background: #00000000;

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 10px;
                            alignment: center;

                            Rectangle {
                                width: 140px;
                                horizontal-stretch: 0;
                                height: parent.height;

                                Text {
                                    width: 100%;
                                    height: 100%;
                                    text: "UI / Terminal Zoom (Ctrl +/-)";
                                    color: AppTheme.text_muted;
                                    font-size: 12px * AppTheme.ui_zoom_factor;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                background: #00000000;
                            }

                            Rectangle {
                                width: 240px;
                                horizontal-stretch: 0;
                                background: #00000000;

                                ComboBox {
                                    width: 100%;
                                    model: root.startup-ui-zoom-choices;
                                    current-value <=> root.startup-ui-zoom;
                                    selected(val) => {
                                        root.shell-ui-zoom-changed(val);
                                    }
                                }
                            }
                        }
                    }

                    Rectangle {
                        height: 42px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 6px;
                        background: #00000000;

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 10px;
                            alignment: center;

                            Rectangle {
                                width: 140px;
                                horizontal-stretch: 0;
                                height: parent.height;

                                Text {
                                    width: 100%;
                                    height: 100%;
                                    text: @tr("語言");
                                    color: AppTheme.text_muted;
                                    font-size: 12px * AppTheme.ui_zoom_factor;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                background: #00000000;
                            }

                            Rectangle {
                                width: 240px;
                                horizontal-stretch: 0;
                                background: #00000000;

                                ComboBox {
                                    width: 100%;
                                    model: root.startup-language-choices;
                                    current-value <=> root.startup-language;
                                    // `changed startup-language` does not always run when the ComboBox updates the binding.
                                    selected(lang) => {
                                        root.shell-ui-language-changed(lang);
                                    }
                                }
                            }
                        }
                    }

                    Rectangle {
                        height: 42px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 6px;
                        background: #00000000;

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 10px;
                            alignment: center;

                            Rectangle {
                                width: 140px;
                                horizontal-stretch: 0;
                                height: parent.height;

                                Text {
                                    width: 100%;
                                    height: 100%;
                                    text: @tr("終端字型");
                                    color: AppTheme.text_muted;
                                    font-size: 12px * AppTheme.ui_zoom_factor;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                background: #00000000;
                            }

                            Rectangle {
                                width: 240px;
                                horizontal-stretch: 0;
                                background: #00000000;

                                ComboBox {
                                    width: 100%;
                                    model: root.startup-terminal-font-choices;
                                    current-value <=> root.startup-terminal-font-family;
                                    selected(val) => {
                                        root.startup-terminal-font-family = val;
                                    }
                                }
                            }
                        }
                    }

                    Rectangle {
                        height: 42px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 6px;
                        background: #00000000;

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 10px;
                            alignment: center;

                            Rectangle {
                                width: 140px;
                                horizontal-stretch: 0;
                                height: parent.height;

                                Text {
                                    width: 100%;
                                    height: 100%;
                                    text: @tr("中文補字字型");
                                    color: AppTheme.text_muted;
                                    font-size: 12px * AppTheme.ui_zoom_factor;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                background: #00000000;
                            }

                            Rectangle {
                                width: 240px;
                                horizontal-stretch: 0;
                                background: #00000000;

                                ComboBox {
                                    width: 100%;
                                    model: root.startup-terminal-cjk-fallback-font-choices;
                                    current-value <=> root.startup-terminal-cjk-fallback-font-family;
                                    selected(val) => {
                                        root.startup-terminal-cjk-fallback-font-family = val;
                                    }
                                }
                            }
                        }
                    }

                    Rectangle {
                        vertical-stretch: 1;
                        background: #00000000;
                    }
                }

                if root.settings-nav == "shell_cmds": VerticalLayout {
                    spacing: 8px;
                    vertical-stretch: 1;

                    Text {
                        text: @tr("預設 Command Prompt / PowerShell 無法刪除；可新增自訂啟動命令。");
                        color: AppTheme.text_muted;
                        font-size: 11px * AppTheme.ui_zoom_factor;
                        horizontal-alignment: left;
                        wrap: word-wrap;
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: end;

                        GjChromeButton {
                            label: @tr("新增");
                            min-button-width: 64px;
                            preset: "add";
                            clicked => {
                                root.add-shell-row();
                            }
                        }
                    }

                    ScrollView {
                        vertical-stretch: 1;
                        min-height: 0px;

                        VerticalLayout {
                            alignment: start;
                            spacing: 6px;

                            for row[key_idx] in root.shell-manage-rows: Rectangle {
                                border-width: 1px;
                                border-color: AppTheme.prompt_chrome_border;
                                border-radius: 6px;
                                background: #00000000;

                                VerticalLayout {
                                    padding: 0px;
                                    spacing: 0px;

                                    Rectangle {
                                        min-height: 34px;
                                        background: #00000000;

                                        HorizontalLayout {
                                            padding-left: 8px;
                                            padding-right: 8px;
                                            spacing: 8px;
                                            alignment: start;

                                            Text {
                                                text: row.expanded ? "v" : ">";
                                                color: AppTheme.text_muted;
                                                font-size: 12px * AppTheme.ui_zoom_factor;
                                                vertical-alignment: center;
                                                horizontal-stretch: 0;
                                                width: 14px;
                                                horizontal-alignment: left;
                                            }

                                            Text {
                                                text: row.name;
                                                color: row.key-locked ? AppTheme.text_muted : AppTheme.text;
                                                font-size: 12px * AppTheme.ui_zoom_factor;
                                                font-weight: 600;
                                                vertical-alignment: center;
                                                horizontal-stretch: 1;
                                                horizontal-alignment: left;
                                                overflow: elide;
                                            }
                                        }

                                        TouchArea {
                                            clicked => {
                                                root.toggle-row-expanded(key_idx);
                                            }
                                        }
                                    }

                                    if row.expanded: VerticalLayout {
                                        padding-left: 8px;
                                        padding-right: 8px;
                                        padding-bottom: 8px;
                                        spacing: 8px;

                                        HorizontalLayout {
                                            spacing: 6px;
                                            alignment: start;

                                            if row.key-locked: Rectangle {
                                                horizontal-stretch: 1;
                                                min-width: 96px;
                                                min-height: 26px;
                                                background: #00000020;
                                                border-radius: 4px;

                                                Text {
                                                    text: row.name;
                                                    color: AppTheme.text_muted;
                                                    font-size: 12px * AppTheme.ui_zoom_factor;
                                                    vertical-alignment: center;
                                                    horizontal-alignment: left;
                                                    overflow: elide;
                                                }
                                            }

                                            if !row.key-locked: LineEdit {
                                                horizontal-stretch: 1;
                                                min-width: 96px;
                                                font-size: 12px * AppTheme.ui_zoom_factor;
                                                text: row.name;
                                                edited(new_text) => {
                                                    root.shell-name-edited(key_idx, new_text);
                                                }
                                            }

                                            Text {
                                                text: ">";
                                                color: AppTheme.text_muted;
                                                font-size: 12px * AppTheme.ui_zoom_factor;
                                                vertical-alignment: center;
                                                horizontal-stretch: 0;
                                            }

                                            LineEdit {
                                                horizontal-stretch: 2;
                                                min-width: 180px;
                                                font-size: 12px * AppTheme.ui_zoom_factor;
                                                text: row.line;
                                                edited(new_text) => {
                                                    root.shell-line-edited(key_idx, new_text);
                                                }
                                            }

                                            GjChromeButton {
                                                label: @tr("刪除");
                                                min-button-width: 44px;
                                                max-button-width: 52px;
                                                button-height: 24px;
                                                pill-corner-radius: 6px;
                                                label-font-size: 11px * AppTheme.ui_zoom_factor;
                                                preset: "danger";
                                                interactive: !row.key-locked;
                                                clicked => {
                                                    root.remove-shell-row(key_idx);
                                                }
                                            }
                                        }

                                        VerticalLayout {
                                            spacing: 4px;

                                            Text {
                                                text: @tr("工作區設定");
                                                color: AppTheme.text_muted;
                                                font-size: 11px * AppTheme.ui_zoom_factor;
                                                horizontal-alignment: left;
                                                wrap: word-wrap;
                                            }

                                            HorizontalLayout {
                                                spacing: 8px;
                                                alignment: start;

                                                LineEdit {
                                                    horizontal-stretch: 1;
                                                    min-height: 28px;
                                                    font-size: 12px * AppTheme.ui_zoom_factor;
                                                    text: row.workspace-path;
                                                    edited(new_text) => {
                                                        root.shell-workspace-edited(key_idx, new_text);
                                                    }
                                                }

                                                GjChromeButton {
                                                    label: @tr("選擇資料夾");
                                                    min-button-width: 88px;
                                                    button-height: 28px;
                                                    preset: "add";
                                                    clicked => {
                                                        root.shell-workspace-pick-folder(key_idx);
                                                    }
                                                }
                                            }

                                            Text {
                                                text: @tr("空白則使用目前工作區（分頁資料夾或啟動目錄）；有填則以該路徑為工作區根目錄。");
                                                color: AppTheme.text_muted;
                                                font-size: 10px * AppTheme.ui_zoom_factor;
                                                horizontal-alignment: left;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: root.manage-saved-hint ? @tr("已儲存設定") : "";
                        color: #7fdc9a;
                        font-size: 12px * AppTheme.ui_zoom_factor;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    GjChromeButton {
                        label: @tr("儲存");
                        min-button-width: 72px;
                        button-height: 28px;
                        preset: "save";
                        clicked => {
                            if root.settings-nav == "startup" {
                                root.save-startup-settings();
                            } else if root.settings-nav == "shell_cmds" {
                                root.save-shell-manage();
                            }
                        }
                    }
                }
            }
        }
    }
}
