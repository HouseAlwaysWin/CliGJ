export global AppTheme {
    in property <color> bg: #0a0a0f;
    in property <color> panel: #14141c;
    in property <color> panel_alt: #1b1b24;
    in property <color> accent: #d1002f;
    in property <color> text: #f3f3f5;
    in property <color> text_muted: #a8a8b0;
    in property <length> gap_sm: 8px;
    in property <length> gap_md: 12px;
    in property <length> radius: 8px;

    // Windows Terminal–style chrome
    in property <color> tab_bar_bg: #1e1e1e;
    in property <color> tab_inactive: #2b2b2b;
    in property <color> tab_active: #1e1e1e;
    in property <color> tab_separator: #3c3c3c;
    in property <length> tab_bar_height: 36px;
    // Fixed tab width: keeps titles readable; overflow uses horizontal ScrollView (no shrink-to "...").
    in property <length> tab_width: 160px;
}
