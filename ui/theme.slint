export global AppTheme {
    /// UI font with Traditional Chinese + Bopomofo coverage on current Windows installs.
    in property <string> ui_font_family: "Microsoft JhengHei";

    in property <color> bg: #0a0a0f;
    in property <color> panel: #14141c;
    in property <color> panel_alt: #1b1b24;
    in property <color> accent: #d1002f;
    in property <color> text: #f3f3f5;
    in property <color> text_muted: #a8a8b0;
    in property <length> gap_sm: 8px;
    in property <length> gap_md: 12px;
    in property <length> radius: 8px;

    in property <length> chrome_resize_border: 8px;
    in property <string> chrome_caption_icon_font: "Segoe MDL2 Assets";

    // Windows Terminal??style chrome
    in property <color> tab_bar_bg: #1e1e1e;
    in property <color> tab_inactive: #2b2b2b;
    in property <color> tab_active: #1e1e1e;
    in property <color> tab_separator: #3c3c3c;
    in property <length> tab_bar_height: 36px;
    // Fixed tab width: keeps titles readable; overflow uses horizontal ScrollView (no shrink-to "...").
    in property <length> tab_width: 160px;

    // VS Code / Cursor-style prompt composer
    in property <color> prompt_chrome_bg: #252526;
    in property <color> prompt_chrome_border: #3c3c3c;
    in property <length> prompt_chrome_radius: 12px;

    /// Prompt bar - send / submit (blue, distinct from `accent` red Raw toggle)
    in property <color> prompt_submit_bg: #1f6feb;
    in property <color> prompt_submit_bg_hover: #388bfd;
    in property <color> prompt_submit_border: #1158c7;

    // `@` file picker - solid muted bar (avoids harsh/cyan-looking overlays on some GPUs)
    in property <color> picker_row_selected: #30343d;
}
