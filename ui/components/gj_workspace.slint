import { AppTheme } from "../theme.slint";
import { PromptImageChip, TermLine } from "../term_types.slint";
import { GjViewer } from "gj_viewer.slint";
import { GjPromptDropZone } from "gj_prompt_drop_zone.slint";
import { GjAtFilePicker } from "gj_at_file_picker.slint";

export component GjWorkspace inherits Rectangle {
    in-out property <string> file-path;
    in-out property <[PromptImageChip]> prompt-images;
    in-out property <[string]> code-lines;
    in-out property <string> terminal-text;
    in-out property <[TermLine]> terminal-lines;
    in-out property <int> terminal-line-offset: 0;
    in-out property <int> terminal-total-lines: 0;
    in-out property <bool> auto-scroll;
    in-out property <bool> terminal-select-mode;
    in-out property <int> selected-line;
    in-out property <string> selected-context;
    in-out property <string> prompt;
    in-out property <[string]> prompt-path-chips;
    in-out property <bool> raw-input-enabled;
    in property <string> terminal-font-family: "DejaVu Sans Mono";
    in property <bool> ipc-running;
    in property <int> ipc-client-count;
    in property <string> ipc-status-text;
    in-out property <bool> at-picker-open;
    in-out property <[string]> at-choices;
    in-out property <int> at-selected;
    in property <string> workspace-root-label;
    in property <[string]> interactive-command-choices;
    callback submit-requested;
    callback history-prev-requested;
    callback history-next-requested;
    callback prompt-key-route(bool, int, string, bool) -> bool;
    callback raw-input-toggle-requested;
    callback ipc-toggle-requested;
    callback inject-file-requested;
    callback workspace-folder-requested;
    callback inject-image-requested;
    callback prompt-image-remove-requested(int);
    callback prompt-images-clear-requested;
    callback prompt-image-zoom-requested(int);
    callback at-picker-choose(int);
    callback prompt-chip-remove-requested(int);
    callback prompt-chip-clear-requested;
    callback terminal-selection-committed(int, int, int, int);
    callback terminal-viewport-changed;
    callback terminal-resize-requested(int, int);
    callback terminal-wheel(int) -> bool;
    callback interactive-command-selected(string);
    callback manage-interactive-commands-requested;
    forward-focus: prompt-zone;

    background: AppTheme.bg;

    public function scroll_terminal_to_bottom() {
        viewer.scroll_to_bottom();
    }

    public function scroll_terminal_to_top() {
        viewer.scroll_to_top();
    }

    /// Re-emit PTY size from the current viewer geometry (e.g. after tab switch).
    public function bump-terminal-size() {
        viewer.bump-terminal-size();
    }

    public function apply-terminal-scroll-top-px(px: float) {
        viewer.apply_scroll_top_px(px);
    }

    public function scroll_at_picker_into_view() {
        at-picker.ensure_selection_visible();
    }

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        viewer := GjViewer {
            terminal-text: root.terminal-text;
            terminal-font-family: root.terminal-font-family;
            terminal-lines <=> root.terminal-lines;
            terminal-line-offset: root.terminal-line-offset;
            terminal-total-lines: root.terminal-total-lines;
            auto-scroll: root.auto-scroll;
            selection-mode: root.terminal-select-mode;
            raw-input-enabled: root.raw-input-enabled;
            selected-line <=> root.selected-line;
            selected-context <=> root.selected-context;
            selection-committed(sr, sc, er, ec) => {
                root.terminal-selection-committed(sr, sc, er, ec);
            }
            viewport-changed => {
                root.terminal-viewport-changed();
            }
            terminal-resize-requested(cols, rows) => {
                root.terminal-resize-requested(cols, rows);
            }
            terminal-wheel(delta) => {
                root.terminal-wheel(delta)
            }
            vertical-stretch: 1;
            min-height: 220px;
        }

        at-picker := GjAtFilePicker {
            open: root.at-picker-open && !root.raw-input-enabled;
            terminal-font-family: root.terminal-font-family;
            root-label: root.workspace-root-label;
            choices: root.at-choices;
            selected-index <=> root.at-selected;
            choose(index) => {
                root.at-picker-choose(index);
            }
        }

        prompt-zone := GjPromptDropZone {
            prompt <=> root.prompt;
            prompt-path-chips: root.prompt-path-chips;
            interactive-command-choices: root.interactive-command-choices;
            raw-input-enabled <=> root.raw-input-enabled;
            ipc-running: root.ipc-running;
            ipc-client-count: root.ipc-client-count;
            ipc-status-text: root.ipc-status-text;
            prompt-images: root.prompt-images;
            selected-context: root.selected-context;
            submit-requested => {
                root.submit-requested();
            }
            history-prev-requested => {
                root.history-prev-requested();
            }
            history-next-requested => {
                root.history-next-requested();
            }
            prompt-key-route(raw, mods, key, shift) => {
                root.prompt-key-route(raw, mods, key, shift);
            }
            raw-input-toggle-requested => {
                root.raw-input-toggle-requested();
            }
            ipc-toggle-requested => {
                root.ipc-toggle-requested();
            }
            inject-file-requested => {
                root.inject-file-requested();
            }
            workspace-folder-requested => {
                root.workspace-folder-requested();
            }
            inject-image-requested => {
                root.inject-image-requested();
            }
            prompt-image-remove-requested(idx) => {
                root.prompt-image-remove-requested(idx);
            }
            prompt-images-clear-requested => {
                root.prompt-images-clear-requested();
            }
            prompt-image-zoom-requested(idx) => {
                root.prompt-image-zoom-requested(idx);
            }
            prompt-chip-remove-requested(index) => {
                root.prompt-chip-remove-requested(index);
            }
            prompt-chip-clear-requested => {
                root.prompt-chip-clear-requested();
            }
            interactive-command-selected(val) => {
                root.interactive-command-selected(val);
            }
            manage-interactive-commands-requested => {
                root.manage-interactive-commands-requested();
            }
        }
    }

    out property <float> terminal-scroll-top-px: viewer.terminal-scroll-top-px;
    out property <float> terminal-viewport-height-px: viewer.terminal-viewport-height-px;
}
