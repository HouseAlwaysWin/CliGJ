import { AppTheme } from "../theme.slint";
import { PromptImageChip } from "../term_types.slint";

export component GjPromptImageLightbox inherits Rectangle {
    width: 100%;
    height: 100%;
    background: #0a0a0fe8;
    z: 450;

    in-out property <int> zoom-index;
    in property <[PromptImageChip]> prompt-images;
    callback open-explorer-for-image-requested(int);
    private property <length> panel-width: min(root.width - 48px * AppTheme.ui_zoom_factor, 900px * AppTheme.ui_zoom_factor);
    private property <length> panel-height: min(root.height - 104px * AppTheme.ui_zoom_factor, 720px * AppTheme.ui_zoom_factor);
    private property <length> nav-button-size: 42px * AppTheme.ui_zoom_factor;
    private property <bool> can-go-prev: root.zoom-index > 0;
    private property <bool> can-go-next: root.zoom-index + 1 < root.prompt-images.length;

    function show-prev() {
        if (root.zoom-index > 0) {
            root.zoom-index -= 1;
        }
    }

    function show-next() {
        if (root.zoom-index + 1 < root.prompt-images.length) {
            root.zoom-index += 1;
        }
    }

    TouchArea {
        width: 100%;
        height: 100%;
        clicked => {
            root.zoom-index = -1;
        }
    }

    VerticalLayout {
        z: 1;
        alignment: center;
        padding: 24px;
        spacing: 10px;

        Rectangle {
            width: root.panel-width;
            height: root.panel-height;
            border-width: 1px;
            border-color: AppTheme.prompt_chrome_border;
            border-radius: 12px;
            background: #14161c;
            clip: true;

            TouchArea {
                width: 100%;
                height: 100%;
            }

            Image {
                source: root.prompt-images[root.zoom-index].thumb;
                width: 100%;
                height: 100%;
                image-fit: contain;
            }

            if root.prompt-images.length > 1 : Rectangle {
                x: 16px;
                y: (parent.height - root.nav-button-size) / 2;
                width: root.nav-button-size;
                height: root.nav-button-size;
                border-width: 1px;
                border-color: root.can-go-prev ? #4f5563 : #343841;
                border-radius: root.nav-button-size / 2;
                background: root.can-go-prev
                    ? (prev-ta.has-hover ? #2a2f39e6 : #1b1f28d8)
                    : #12151cc8;

                Text {
                    text: "<";
                    width: 100%;
                    height: 100%;
                    color: root.can-go-prev ? #f3f5f8 : #656b78;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    font-size: 22px * AppTheme.ui_zoom_factor;
                    font-weight: 700;
                }

                prev-ta := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    enabled: root.can-go-prev;
                    clicked => {
                        root.show-prev();
                    }
                }
            }

            if root.prompt-images.length > 1 : Rectangle {
                x: parent.width - self.width - 16px;
                y: (parent.height - root.nav-button-size) / 2;
                width: root.nav-button-size;
                height: root.nav-button-size;
                border-width: 1px;
                border-color: root.can-go-next ? #4f5563 : #343841;
                border-radius: root.nav-button-size / 2;
                background: root.can-go-next
                    ? (next-ta.has-hover ? #2a2f39e6 : #1b1f28d8)
                    : #12151cc8;

                Text {
                    text: ">";
                    width: 100%;
                    height: 100%;
                    color: root.can-go-next ? #f3f5f8 : #656b78;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    font-size: 22px * AppTheme.ui_zoom_factor;
                    font-weight: 700;
                }

                next-ta := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    enabled: root.can-go-next;
                    clicked => {
                        root.show-next();
                    }
                }
            }
        }

        Text {
            text: "\{root.zoom-index + 1} / \{root.prompt-images.length}";
            color: #f3f5f8;
            font-size: 12px * AppTheme.ui_zoom_factor;
            horizontal-alignment: center;
        }

        Rectangle {
            width: min(root.panel-width - 32px, root.width - 80px);
            min-height: 44px;

            VerticalLayout {
                spacing: 4px;
                width: 100%;

                Text {
                    text: @tr("點擊：在檔案總管開啟");
                    color: AppTheme.text_muted;
                    font-size: 11px * AppTheme.ui_zoom_factor;
                    horizontal-alignment: center;
                    width: 100%;
                }

                VerticalLayout {
                    spacing: 0px;
                    width: 100%;

                    Text {
                        text: root.prompt-images[root.zoom-index].abs-path;
                        color: AppTheme.prompt_submit_bg;
                        font-size: 11px * AppTheme.ui_zoom_factor;
                        horizontal-alignment: center;
                        overflow: elide;
                        wrap: no-wrap;
                        width: 100%;
                    }

                    Rectangle {
                        height: 1px;
                        width: 100%;
                        background: AppTheme.prompt_submit_bg;
                    }
                }
            }

            TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: pointer;
                pointer-event(e) => {
                    if (e.kind == PointerEventKind.up
                        && e.button == PointerEventButton.left) {
                        root.open-explorer-for-image-requested(root.zoom-index);
                    }
                }
            }
        }

        Text {
            text: @tr("點擊任意處關閉");
            color: AppTheme.text_muted;
            font-size: 12px * AppTheme.ui_zoom_factor;
            horizontal-alignment: center;
        }
    }
}
