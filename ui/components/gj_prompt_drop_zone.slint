import { TextEdit } from "std-widgets.slint";
import { AppTheme } from "../theme.slint";

/// Bottom prompt bar: a single VS Code-like input.
export component GjPromptDropZone inherits Rectangle {
    in-out property <string> prompt;
    in property <bool> has-image;
    in property <image> preview-image;
    in property <string> selected-context;

    horizontal-stretch: 1;
    min-height: 92px;
    background: AppTheme.bg;
    border-width: 0px;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: AppTheme.bg;

        Rectangle {
            x: 8px;
            y: 8px;
            width: parent.width - 16px;
            height: parent.height - 16px;
            background: AppTheme.prompt_chrome_bg;
            border-width: 1px;
            border-color: AppTheme.prompt_chrome_border;
            border-radius: AppTheme.prompt_chrome_radius;

            TextEdit {
                x: 10px;
                y: 8px;
                width: parent.width - 20px;
                height: parent.height - 16px;
                text <=> root.prompt;
                placeholder-text: "輸入 Prompt...";
                font-size: 13px;
                wrap: word-wrap;
            }
        }
    }
}
