import { TextEdit } from "std-widgets.slint";
import { AppTheme } from "../theme.slint";

/// Bottom prompt bar: input + function bar (Cursor/VSCode style).
export component GjPromptDropZone inherits Rectangle {
    in-out property <string> prompt;
    in property <bool> has-image;
    in property <image> preview-image;
    in property <string> selected-context;
    callback submit-requested;

    horizontal-stretch: 1;
    min-height: 116px;
    max-height: 116px;
    background: AppTheme.bg;
    border-width: 0px;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: AppTheme.bg;

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: AppTheme.prompt_chrome_bg;
            border-width: 1px;
            border-color: AppTheme.prompt_chrome_border;
            border-radius: AppTheme.prompt_chrome_radius;

            VerticalLayout {
                padding: 8px;
                spacing: 4px;

                TextEdit {
                    horizontal-stretch: 1;
                    min-height: 68px;
                    text <=> root.prompt;
                    placeholder-text: "Plan, Build, / for commands, @ for context";
                    font-size: 13px;
                    wrap: word-wrap;
                    key-pressed(event) => {
                        if ((event.text == Key.Return || event.text == "\n" || event.text == "\u{000d}") && !event.modifiers.shift) {
                            root.submit-requested();
                            accept
                        } else {
                            reject
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;

                    Rectangle {
                        min-width: 78px;
                        height: 22px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: #00000000;

                        Text {
                            text: "Agent";
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 11px;
                        }
                    }

                    Rectangle {
                        min-width: 54px;
                        height: 22px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: #00000000;

                        Text {
                            text: "Auto";
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 11px;
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        background: #00000000;
                    }

                    Rectangle {
                        min-width: 28px;
                        height: 22px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: #00000000;

                        Text {
                            text: "R";
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 11px;
                        }
                    }

                    Rectangle {
                        min-width: 36px;
                        height: 22px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: #00000000;

                        Text {
                            text: "Img";
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 11px;
                        }
                    }

                    Rectangle {
                        min-width: 34px;
                        height: 22px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: #00000000;

                        Text {
                            text: "Mic";
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 11px;
                        }
                    }

                    Rectangle {
                        width: 34px;
                        height: 22px;
                        border-width: 1px;
                        border-color: AppTheme.accent;
                        border-radius: 11px;
                        background: submit_ta.has-hover ? #ff4f6f : AppTheme.accent;

                        Text {
                            text: "↑";
                            color: AppTheme.text;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 12px;
                            font-weight: 700;
                        }

                        submit_ta := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => {
                                root.submit-requested();
                            }
                        }
                    }
                }
            }
        }
    }
}
