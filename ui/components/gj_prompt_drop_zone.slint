import { ComboBox, LineEdit, ScrollView, TextEdit } from "std-widgets.slint";
import { AppTheme } from "../theme.slint";
import { LogicalKey } from "../key_labels.slint";
import { PromptImageChip } from "../term_types.slint";

/// Bottom prompt bar: input + function bar (Cursor/VSCode style).
export component GjPromptDropZone inherits Rectangle {
    in-out property <string> prompt;
    in property <[string]> prompt-path-chips: [];
    in property <bool> raw-input-enabled: false;
    in-out property <string> terminal-pin-lines: "0";
    in property <bool> ipc-running: false;
    in property <int> ipc-client-count: 0;
    in property <string> ipc-status-text: "IPC OFF";
    in property <[string]> interactive-command-choices: [];
    in property <[PromptImageChip]> prompt-images;
    in property <string> selected-context;
    callback submit-requested;
    callback history-prev-requested;
    callback history-next-requested;
    /// Returns true to `accept` the key (consume); false to `reject` (default editor handling).
    /// Modifier bits: 1=Ctrl, 2=Shift, 4=Alt, 8=Meta — must match `key_encoding::mod_bits`.
    callback prompt-key-route(bool, int, string, bool) -> bool;
    callback raw-input-toggle-requested;
    callback terminal-pin-lines-edited(string);
    callback ipc-toggle-requested;
    callback inject-file-requested;
    callback workspace-folder-requested;
    callback inject-image-requested;
    callback prompt-image-remove-requested(int);
    callback prompt-images-clear-requested;
    callback prompt-image-zoom-requested(int);
    callback prompt-chip-remove-requested(int);
    callback prompt-chip-clear-requested;
    /// Ctrl + 滑鼠左鍵：在檔案總管顯示該路徑（依 chip 索引對應 Rust 端的絕對路徑）。
    callback prompt-path-chip-open-editor-requested(int);
    callback prompt-path-chip-open-explorer-requested(int);
    callback prompt-image-open-explorer-requested(int);
    callback interactive-command-selected(string);
    callback manage-interactive-commands-requested;
    callback terminal-history-requested;
    forward-focus: prompt-input;
    private property <length> image-chip-width: 120px;
    private property <length> image-chip-gap: 8px;
    private property <length> image-row-height: 52px;
    private property <length> image-strip-extra-height: 60px;
    private property <length> image-clear-button-width: 92px;
    private property <length> image-clear-button-height: 22px;
    private property <length> image-strip-content-width: root.prompt-images.length > 0
        ? root.prompt-images.length * root.image-chip-width
            + (root.prompt-images.length - 1) * root.image-chip-gap
        : 0px;

    function pty_mod(event: KeyEvent) -> int {
        (event.modifiers.control ? 1 : 0)
        + (event.modifiers.shift ? 2 : 0)
        + (event.modifiers.alt ? 4 : 0)
        + (event.modifiers.meta ? 8 : 0)
    }

    horizontal-stretch: 1;
    // Base 116px; +28px file chip strip; +60px image strip (thumbnails row).
    min-height: 116px
        + (root.prompt-path-chips.length > 0 ? 28px : 0px)
        + (root.prompt-images.length > 0 ? root.image-strip-extra-height : 0px);
    max-height: 116px
        + (root.prompt-path-chips.length > 0 ? 28px : 0px)
        + (root.prompt-images.length > 0 ? root.image-strip-extra-height : 0px);
    background: AppTheme.bg;
    border-width: 0px;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: AppTheme.bg;

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: AppTheme.prompt_chrome_bg;
            border-width: 1px;
            border-color: AppTheme.prompt_chrome_border;
            border-radius: AppTheme.prompt_chrome_radius;

            VerticalLayout {
                padding: 8px;
                spacing: 4px;

                if root.prompt-path-chips.length > 0 : Rectangle {
                    min-height: 24px;
                    max-height: 24px;
                    background: #00000000;
                    HorizontalLayout {
                        height: 22px;
                        spacing: 6px;

                        for chip[idx] in root.prompt-path-chips: Rectangle {
                            width: self.preferred-width;
                            height: 22px;
                            border-width: 1px;
                            border-color: #ff3b6d;
                            border-radius: 12px;
                            background: #14161c;

                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 4px;
                                spacing: 8px;

                                Rectangle {
                                    horizontal-stretch: 1;
                                    height: parent.height;
                                    background: #00000000;

                                    HorizontalLayout {
                                        spacing: 8px;

                                        Text {
                                            text: "file";
                                            color: #b5bcc8;
                                            vertical-alignment: center;
                                            font-size: 11px;
                                        }
                                        Text {
                                            text: chip;
                                            color: AppTheme.prompt_submit_bg;
                                            vertical-alignment: center;
                                            font-size: 12px;
                                            font-weight: 600;
                                        }
                                    }

                                    chip_ta := TouchArea {
                                        pointer-event(e) => {
                                            if (e.kind == PointerEventKind.up
                                                && e.button == PointerEventButton.left) {
                                                if (e.modifiers.control) {
                                                    root.prompt-path-chip-open-explorer-requested(idx);
                                                } else {
                                                    root.prompt-path-chip-open-editor-requested(idx);
                                                }
                                            }
                                        }
                                    }
                                }

                                Rectangle {
                                    width: 18px;
                                    height: parent.height;
                                    background: #00000000;

                                    Text {
                                        text: "x";
                                        color: #ff8ca8;
                                        vertical-alignment: center;
                                        horizontal-alignment: center;
                                        font-size: 11px;
                                        width: 100%;
                                        height: 100%;
                                    }

                                    TouchArea {
                                        width: parent.width;
                                        height: parent.height;
                                        clicked => {
                                            root.prompt-chip-remove-requested(idx);
                                        }
                                    }
                                }
                            }

                            if chip_ta.has-hover: Rectangle {
                                y: -22px;
                                x: 0px;
                                width: 214px;
                                height: 18px;
                                border-radius: 4px;
                                background: #20232b;
                                border-width: 1px;
                                border-color: AppTheme.prompt_chrome_border;

                                Text {
                                    text: @tr("Ctrl+左鍵：開啟位置");
                                    color: AppTheme.text_muted;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    font-size: 9px;
                                }
                            }
                        }

                        Rectangle {
                            width: self.preferred-width;
                            height: 22px;
                            border-width: 1px;
                            border-color: AppTheme.prompt_chrome_border;
                            border-radius: 12px;
                            background: #00000000;

                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                spacing: 6px;
                                Text {
                                    text: @tr("取消");
                                    color: AppTheme.text_muted;
                                    vertical-alignment: center;
                                    font-size: 11px;
                                }
                            }

                            TouchArea {
                                clicked => {
                                    root.prompt-chip-clear-requested();
                                }
                            }
                        }
                    }
                }

                if root.prompt-images.length > 0 : Rectangle {
                    min-height: root.image-row-height;
                    max-height: root.image-row-height;
                    background: #00000000;
                    property <length> image-strip-viewport-width:
                        max(0px, self.width - root.image-clear-button-width - root.image-chip-gap);

                    Rectangle {
                        x: 0px;
                        y: 0px;
                        width: parent.image-strip-viewport-width;
                        height: root.image-row-height;
                        background: #00000000;
                        clip: true;

                        image-strip-ta := TouchArea {
                            width: parent.width;
                            height: parent.height;

                            image-scroll := ScrollView {
                                width: parent.width;
                                height: root.image-row-height;
                                viewport-width: root.image-strip-content-width;
                                viewport-height: root.image-row-height;
                                horizontal-scrollbar-policy: as-needed;
                                vertical-scrollbar-policy: always-off;
                                mouse-drag-pan-enabled: true;

                                Rectangle {
                                    width: root.image-strip-content-width;
                                    height: root.image-row-height;
                                    background: #00000000;

                                    for row[idx] in root.prompt-images: Rectangle {
                                        x: idx * (root.image-chip-width + root.image-chip-gap);
                                        y: 0px;
                                        width: root.image-chip-width;
                                        height: root.image-row-height;
                                        border-width: 1px;
                                        border-color: #4a9eff;
                                        border-radius: 10px;
                                        background: #14161c;
                                        clip: true;

                                        HorizontalLayout {
                                            padding-left: 6px;
                                            padding-right: 6px;
                                            spacing: 6px;

                                            Rectangle {
                                                width: 40px;
                                                height: 40px;
                                                border-radius: 6px;
                                                clip: true;
                                                y: (parent.height - self.height) / 2;

                                                Image {
                                                    source: row.thumb;
                                                    width: 100%;
                                                    height: 100%;
                                                    image-fit: cover;
                                                }

                                                TouchArea {
                                                    width: parent.width;
                                                    height: parent.height;
                                                    clicked => {
                                                        root.prompt-image-zoom-requested(idx);
                                                    }
                                                }
                                            }

                                            Rectangle {
                                                horizontal-stretch: 1;
                                                min-width: 0px;
                                                height: parent.height;

                                                VerticalLayout {
                                                    alignment: start;
                                                    spacing: 0px;
                                                    y: max(0px, (parent.height - self.preferred-height) / 2);
                                                    horizontal-stretch: 1;
                                                    min-width: 0px;

                                                    Text {
                                                        text: row.label;
                                                        color: AppTheme.prompt_submit_bg;
                                                        vertical-alignment: center;
                                                        font-size: 11px;
                                                        font-weight: 600;
                                                        overflow: elide;
                                                        horizontal-stretch: 1;
                                                        min-width: 0px;
                                                    }

                                                    Rectangle {
                                                        height: 1px;
                                                        horizontal-stretch: 1;
                                                        min-width: 0px;
                                                        background: AppTheme.prompt_submit_bg;
                                                    }
                                                }

                                                TouchArea {
                                                    width: parent.width;
                                                    height: parent.height;
                                                    pointer-event(e) => {
                                                        if (e.kind == PointerEventKind.up
                                                            && e.button == PointerEventButton.left
                                                            && e.modifiers.control) {
                                                            root.prompt-image-open-explorer-requested(idx);
                                                        }
                                                    }
                                                }
                                            }

                                            Rectangle {
                                                width: 18px;
                                                height: parent.height;

                                                Text {
                                                    text: "x";
                                                    color: #ff8ca8;
                                                    vertical-alignment: center;
                                                    horizontal-alignment: center;
                                                    font-size: 11px;
                                                    width: 100%;
                                                    height: parent.height;
                                                }

                                                TouchArea {
                                                    width: parent.width;
                                                    height: parent.height;
                                                    clicked => {
                                                        root.prompt-image-remove-requested(idx);
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            scroll-event(event) => {
                                let max-scroll = image-scroll.viewport-width - image-scroll.visible-width;
                                if (max-scroll <= 0px) {
                                    return reject;
                                }
                                let next = image-scroll.viewport-x - event.delta-y - event.delta-x;
                                image-scroll.viewport-x = max(-max-scroll, min(0px, next));
                                return accept;
                            }
                        }
                    }

                    Rectangle {
                        x: parent.width - root.image-clear-button-width;
                        y: (parent.height - root.image-clear-button-height) / 2;
                        width: root.image-clear-button-width;
                        height: root.image-clear-button-height;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 12px;
                        background: #00000000;

                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            spacing: 6px;
                            Text {
                                text: @tr("清除圖");
                                color: AppTheme.text_muted;
                                vertical-alignment: center;
                                font-size: 11px;
                            }
                        }

                        TouchArea {
                            clicked => {
                                root.prompt-images-clear-requested();
                            }
                        }
                    }
                }

                prompt-input := TextEdit {
                    horizontal-stretch: 1;
                    min-height: 68px;
                    text <=> root.prompt;
                    placeholder-text: root.raw-input-enabled
                        ? @tr("TTY mode: keys go to terminal; @ / Shift+Tab still work. Turn off Raw mode for line composer + inject")
                        : @tr("Plan, Build, / - @ search files - use file/image buttons, drag and drop, or Ctrl+V");
                    font-family: AppTheme.ui_font_family;
                    font-size: 13px;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: 6px;

                    HorizontalLayout {
                        spacing: 4px;
                        alignment: start;
                        horizontal-stretch: 0;

                        // Cap width so long labels don't stretch the bar; popup uses native scrolling.
                        Rectangle {
                            width: 168px;
                            height: 22px;
                            horizontal-stretch: 0;

                            ComboBox {
                                width: 100%;
                                height: 22px;
                                model: root.interactive-command-choices;
                                current-value: @tr("選擇指令");
                                selected(val) => {
                                    root.interactive-command-selected(val);
                                    self.current-value = @tr("選擇指令");
                                }
                            }
                        }

                        Rectangle {
                            width: 28px;
                            height: 22px;
                            horizontal-stretch: 0;
                            border-width: 1px;
                            border-color: AppTheme.prompt_chrome_border;
                            border-radius: 11px;
                            background: #00000000;

                            Text {
                                // ASCII — U+2026 ellipsis is missing from some embedded fonts (shows as tofu).
                                text: "...";
                                color: AppTheme.text_muted;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                font-size: 11px;
                                font-weight: 700;
                            }

                            manage_cmds_ta := TouchArea {
                                accessible-role: button;
                                accessible-label: @tr("管理互動指令");
                                clicked => {
                                    root.manage-interactive-commands-requested();
                                }
                            }

                            if manage_cmds_ta.has-hover: Rectangle {
                                y: -22px;
                                x: -20px;
                                width: 72px;
                                height: 18px;
                                border-radius: 4px;
                                background: #20232b;
                                border-width: 1px;
                                border-color: AppTheme.prompt_chrome_border;
                                Text {
                                    text: @tr("管理指令");
                                    color: AppTheme.text_muted;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    font-size: 9px;
                                }
                            }
                        }

                        Rectangle {
                            width: 28px;
                            height: 22px;
                            horizontal-stretch: 0;
                            border-width: 1px;
                            border-color: AppTheme.prompt_chrome_border;
                            border-radius: 11px;
                            background: #00000000;

                            Image {
                                width: 14px;
                                height: 14px;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                source: @image-url("../icons/prompt_workspace.svg");
                                colorize: AppTheme.text_muted;
                            }

                            workspace_ta := TouchArea {
                                accessible-role: button;
                                accessible-label: @tr("選擇工作區資料夾");
                                clicked => {
                                    root.workspace-folder-requested();
                                }
                            }

                            if workspace_ta.has-hover: Rectangle {
                                y: -22px;
                                x: (parent.width - self.width) / 2;
                                width: 104px;
                                height: 18px;
                                border-radius: 4px;
                                background: #20232b;
                                border-width: 1px;
                                border-color: AppTheme.prompt_chrome_border;
                                Text {
                                    text: @tr("選擇工作區資料夾");
                                    color: AppTheme.text_muted;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    font-size: 9px;
                                }
                            }
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        background: #00000000;
                    }

                    Rectangle {
                        min-width: 86px;
                        height: 22px;
                        horizontal-stretch: 0;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: #00000000;

                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 6px;
                            spacing: 6px;

                            Rectangle {
                                width: 22px;
                                height: parent.height;
                                background: #00000000;

                                Image {
                                    width: 14px;
                                    height: 14px;
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                    source: @image-url("../icons/prompt_pin.svg");
                                    colorize: AppTheme.text_muted;
                                }

                                pin_tip_ta := TouchArea {
                                    width: parent.width;
                                    height: parent.height;
                                    accessible-role: text;
                                    accessible-label: @tr("固定底部");
                                }

                                if pin_tip_ta.has-hover: Rectangle {
                                    y: -22px;
                                    x: (parent.width - self.width) / 2;
                                    width: 72px;
                                    height: 18px;
                                    border-radius: 4px;
                                    background: #20232b;
                                    border-width: 1px;
                                    border-color: AppTheme.prompt_chrome_border;
                                    Text {
                                        text: @tr("固定底部");
                                        color: AppTheme.text_muted;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        font-size: 9px;
                                    }
                                }
                            }

                            LineEdit {
                                horizontal-stretch: 1;
                                min-width: 60px;
                                text <=> root.terminal-pin-lines;
                                font-size: 11px;
                                edited(new_text) => {
                                    root.terminal-pin-lines-edited(new_text);
                                }
                            }
                        }
                    }

                    // History: icon button
                    Rectangle {
                        width: 28px;
                        height: 22px;
                        horizontal-stretch: 0;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: #00000000;

                        Image {
                            width: 14px;
                            height: 14px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            source: @image-url("../icons/prompt_history.svg");
                            colorize: AppTheme.text_muted;
                        }

                        history_ta := TouchArea {
                            accessible-role: button;
                            accessible-label: @tr("終端歷史");
                            clicked => {
                                root.terminal-history-requested();
                            }
                        }

                        if history_ta.has-hover: Rectangle {
                            y: -22px;
                            x: -12px;
                            width: 60px;
                            height: 18px;
                            border-radius: 4px;
                            background: #20232b;
                            border-width: 1px;
                            border-color: AppTheme.prompt_chrome_border;
                            Text {
                                text: @tr("終端歷史");
                                color: AppTheme.text_muted;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                font-size: 9px;
                            }
                        }
                    }

                    Rectangle {
                        width: 28px;
                        height: 22px;
                        horizontal-stretch: 0;
                        border-width: 1px;
                        border-color: root.raw-input-enabled ? AppTheme.accent : AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: root.raw-input-enabled ? #ff4f6f : #00000000;

                        Image {
                            width: 14px;
                            height: 14px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            source: root.raw-input-enabled
                                ? @image-url("../icons/prompt_raw_on.svg")
                                : @image-url("../icons/prompt_raw_off.svg");
                            colorize: root.raw-input-enabled ? AppTheme.text : AppTheme.text_muted;
                        }

                        raw_toggle_ta := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            accessible-role: button;
                            accessible-label: root.raw-input-enabled
                                ? @tr("原始輸入：按鍵送往終端（Alt+F1）")
                                : @tr("行內編輯：關閉原始輸入以使用插入與組字（Alt+F1）");
                            accessible-checkable: true;
                            accessible-checked: root.raw-input-enabled;
                            clicked => {
                                root.raw-input-toggle-requested();
                            }
                        }

                        if raw_toggle_ta.has-hover: Rectangle {
                            y: -22px;
                            x: -18px;
                            width: 95px;
                            height: 18px;
                            border-radius: 4px;
                            background: #20232b;
                            border-width: 1px;
                            border-color: AppTheme.prompt_chrome_border;
                            Text {
                                text: @tr("原生 Alt+F1");
                                color: AppTheme.text_muted;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                font-size: 9px;
                            }
                        }
                    }

                    // IPC: SVG 鏈條；連線中顯示客戶端數量
                    Rectangle {
                        width: root.ipc-running && root.ipc-client-count > 0 ? 38px : 28px;
                        height: 22px;
                        horizontal-stretch: 0;
                        border-width: 1px;
                        border-color: root.ipc-running ? #4fb67b : AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: root.ipc-running ? #193126 : #00000000;

                        Image {
                            width: 20px;
                            height: 20px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            source: @image-url("../icons/prompt_ipc.svg");
                            colorize: root.ipc-running ? #97f5be : AppTheme.text_muted;
                        }

                        if root.ipc-running && root.ipc-client-count > 0: Text {
                            text: "\{root.ipc-client-count}";
                            color: #97f5be;
                            font-size: 8px;
                            font-weight: 700;
                            x: parent.width - self.width - 4px;
                            y: 1px;
                        }

                        ipc_toggle_ta := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            accessible-role: button;
                            accessible-label: root.ipc-status-text;
                            clicked => {
                                root.ipc-toggle-requested();
                            }
                        }

                        if ipc_toggle_ta.has-hover: Rectangle {
                            y: -22px;
                            x: -14px;
                            width: 58px;
                            height: 18px;
                            border-radius: 4px;
                            background: #20232b;
                            border-width: 1px;
                            border-color: AppTheme.prompt_chrome_border;
                            Text {
                                text: @tr("IPC");
                                color: AppTheme.text_muted;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                font-size: 9px;
                            }
                        }
                    }

                    Rectangle {
                        width: 28px;
                        height: 22px;
                        horizontal-stretch: 0;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: #00000000;

                        Image {
                            width: 14px;
                            height: 14px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            source: @image-url("../icons/prompt_file.svg");
                            colorize: AppTheme.text_muted;
                        }

                        inject_file_ta := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            accessible-role: button;
                            accessible-label: @tr("插入檔案");
                            clicked => {
                                root.inject-file-requested();
                            }
                        }

                        if inject_file_ta.has-hover: Rectangle {
                            y: -22px;
                            x: -16px;
                            width: 64px;
                            height: 18px;
                            border-radius: 4px;
                            background: #20232b;
                            border-width: 1px;
                            border-color: AppTheme.prompt_chrome_border;
                            Text {
                                text: @tr("檔案");
                                color: AppTheme.text_muted;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                font-size: 9px;
                            }
                        }
                    }

                    Rectangle {
                        width: 28px;
                        height: 22px;
                        horizontal-stretch: 0;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: #00000000;

                        Text {
                            width: 100%;
                            height: 100%;
                            // EB9F = Photo（山景框）；E8B9 在 MDL2 常是字型／字元，會變成 A+▼
                            text: "\u{eb9f}";
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 12px;
                            font-family: AppTheme.chrome_caption_icon_font;
                        }

                        image_ta := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            accessible-role: button;
                            accessible-label: @tr("插入圖片");
                            clicked => {
                                root.inject-image-requested();
                            }
                        }

                        if image_ta.has-hover: Rectangle {
                            y: -22px;
                            x: -16px;
                            width: 64px;
                            height: 18px;
                            border-radius: 4px;
                            background: #20232b;
                            border-width: 1px;
                            border-color: AppTheme.prompt_chrome_border;
                            Text {
                                text: @tr("插圖");
                                color: AppTheme.text_muted;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                font-size: 9px;
                            }
                        }
                    }

                    Rectangle {
                        width: 34px;
                        height: 22px;
                        horizontal-stretch: 0;
                        border-width: 1px;
                        border-color: AppTheme.prompt_submit_border;
                        border-radius: 11px;
                        background: submit_ta.has-hover
                            ? AppTheme.prompt_submit_bg_hover
                            : AppTheme.prompt_submit_bg;

                        Text {
                            text: "↑";
                            color: AppTheme.text;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 12px;
                            font-weight: 700;
                        }

                        submit_ta := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            accessible-role: button;
                            accessible-label: @tr("送出（Enter）");
                            clicked => {
                                root.submit-requested();
                            }
                        }

                        if submit_ta.has-hover: Rectangle {
                            y: -22px;
                            x: -12px;
                            width: 60px;
                            height: 18px;
                            border-radius: 4px;
                            background: #20232b;
                            border-width: 1px;
                            border-color: AppTheme.prompt_chrome_border;
                            Text {
                                text: @tr("Enter");
                                color: AppTheme.text_muted;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                font-size: 9px;
                            }
                        }
                    }
                }
            }
        }
    }
}
