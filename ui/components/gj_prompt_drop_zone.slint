import { TextEdit } from "std-widgets.slint";
import { AppTheme } from "../theme.slint";
import { LogicalKey } from "../key_labels.slint";

/// Bottom prompt bar: input + function bar (Cursor/VSCode style).
export component GjPromptDropZone inherits Rectangle {
    in-out property <string> prompt;
    in property <[string]> prompt-path-chips: [];
    in property <bool> raw-input-enabled: false;
    in property <bool> has-image;
    in property <image> preview-image;
    in property <string> selected-context;
    callback submit-requested;
    callback history-prev-requested;
    callback history-next-requested;
    /// Returns true to `accept` the key (consume); false to `reject` (default editor handling).
    /// Modifier bits: 1=Ctrl, 2=Shift, 4=Alt, 8=Meta — must match `key_encoding::mod_bits`.
    callback prompt-key-route(bool, int, string, bool) -> bool;
    callback raw-input-toggle-requested;
    callback inject-file-requested;
    callback prompt-chip-remove-requested(int);
    callback prompt-chip-clear-requested;

    function pty_mod(event: KeyEvent) -> int {
        (event.modifiers.control ? 1 : 0)
        + (event.modifiers.shift ? 2 : 0)
        + (event.modifiers.alt ? 4 : 0)
        + (event.modifiers.meta ? 8 : 0)
    }

    horizontal-stretch: 1;
    // Fixed 116px fits chips row + TextEdit + bar only when the chip strip is hidden; with chips, add ~28px.
    min-height: root.prompt-path-chips.length > 0 ? 144px : 116px;
    max-height: root.prompt-path-chips.length > 0 ? 144px : 116px;
    background: AppTheme.bg;
    border-width: 0px;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: AppTheme.bg;

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: AppTheme.prompt_chrome_bg;
            border-width: 1px;
            border-color: AppTheme.prompt_chrome_border;
            border-radius: AppTheme.prompt_chrome_radius;

            VerticalLayout {
                padding: 8px;
                spacing: 4px;

                if root.prompt-path-chips.length > 0 : Rectangle {
                    min-height: 24px;
                    max-height: 24px;
                    background: #00000000;
                    HorizontalLayout {
                        height: 22px;
                        spacing: 6px;

                        for chip[idx] in root.prompt-path-chips: Rectangle {
                            width: self.preferred-width;
                            height: 22px;
                            border-width: 1px;
                            border-color: #ff3b6d;
                            border-radius: 12px;
                            background: #14161c;

                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                spacing: 8px;

                                Text {
                                    text: "file";
                                    color: #b5bcc8;
                                    vertical-alignment: center;
                                    font-size: 11px;
                                }
                                Text {
                                    text: chip;
                                    color: #f3f5f8;
                                    vertical-alignment: center;
                                    font-size: 12px;
                                    font-weight: 600;
                                }
                                Text {
                                    text: "x";
                                    color: #ff8ca8;
                                    vertical-alignment: center;
                                    font-size: 11px;
                                }
                            }

                            TouchArea {
                                clicked => {
                                    root.prompt-chip-remove-requested(idx);
                                }
                            }
                        }

                        Rectangle {
                            width: self.preferred-width;
                            height: 22px;
                            border-width: 1px;
                            border-color: AppTheme.prompt_chrome_border;
                            border-radius: 12px;
                            background: #00000000;

                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                spacing: 6px;
                                Text {
                                    text: "取消";
                                    color: AppTheme.text_muted;
                                    vertical-alignment: center;
                                    font-size: 11px;
                                }
                            }

                            TouchArea {
                                clicked => {
                                    root.prompt-chip-clear-requested();
                                }
                            }
                        }
                    }
                }

                TextEdit {
                    horizontal-stretch: 1;
                    min-height: 68px;
                    text <=> root.prompt;
                    placeholder-text: root.raw-input-enabled
                        ? "TTY: keys → terminal — @ / Shift+Tab work here; R OFF for line composer + inject"
                        : "Plan, Build, / — 輸入 @ 搜尋並插入工作區檔案（關鍵字篩選）— File 按鈕可注入檔";
                    font-size: 13px;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: 8px;

                    Rectangle {
                        min-width: 78px;
                        height: 22px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: #00000000;

                        Text {
                            text: "Agent";
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 11px;
                        }
                    }

                    Rectangle {
                        min-width: 54px;
                        height: 22px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: #00000000;

                        Text {
                            text: "Auto";
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 11px;
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        background: #00000000;
                    }

                    Rectangle {
                        min-width: 56px;
                        height: 22px;
                        border-width: 1px;
                        border-color: root.raw-input-enabled ? AppTheme.accent : AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: root.raw-input-enabled ? #ff4f6f : #00000000;

                        Text {
                            text: root.raw-input-enabled ? "R ON" : "R OFF";
                            color: root.raw-input-enabled ? AppTheme.text : AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 10px;
                        }

                        TouchArea {
                            clicked => {
                                root.raw-input-toggle-requested();
                            }
                        }
                    }

                    Rectangle {
                        min-width: 40px;
                        height: 22px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: #00000000;

                        Text {
                            text: "File";
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 11px;
                        }

                        inject_file_ta := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => {
                                root.inject-file-requested();
                            }
                        }
                    }

                    Rectangle {
                        min-width: 36px;
                        height: 22px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: #00000000;

                        Text {
                            text: "Img";
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 11px;
                        }
                    }

                    Rectangle {
                        min-width: 34px;
                        height: 22px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: #00000000;

                        Text {
                            text: "Mic";
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 11px;
                        }
                    }

                    Rectangle {
                        width: 34px;
                        height: 22px;
                        border-width: 1px;
                        border-color: AppTheme.accent;
                        border-radius: 11px;
                        background: submit_ta.has-hover ? #ff4f6f : AppTheme.accent;

                        Text {
                            text: "↑";
                            color: AppTheme.text;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 12px;
                            font-weight: 700;
                        }

                        submit_ta := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => {
                                root.submit-requested();
                            }
                        }
                    }
                }
            }
        }
    }
}
