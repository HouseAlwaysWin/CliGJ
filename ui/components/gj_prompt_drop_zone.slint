import { TextEdit } from "std-widgets.slint";
import { AppTheme } from "../theme.slint";

/// Bottom prompt bar: input + function bar (Cursor/VSCode style).
export component GjPromptDropZone inherits Rectangle {
    in-out property <string> prompt;
    in property <bool> raw-input-enabled: false;
    in property <bool> has-image;
    in property <image> preview-image;
    in property <string> selected-context;
    callback submit-requested;
    callback history-prev-requested;
    callback history-next-requested;
    /// Modifier bits: 1=Ctrl, 2=Shift, 4=Alt, 8=Meta — must match `key_encoding::mod_bits`.
    callback pty-key-requested(int, string);
    callback raw-input-toggle-requested;
    callback inject-file-requested;

    function pty_mod(event: KeyEvent) -> int {
        (event.modifiers.control ? 1 : 0)
        + (event.modifiers.shift ? 2 : 0)
        + (event.modifiers.alt ? 4 : 0)
        + (event.modifiers.meta ? 8 : 0)
    }

    horizontal-stretch: 1;
    min-height: 116px;
    max-height: 116px;
    background: AppTheme.bg;
    border-width: 0px;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: AppTheme.bg;

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: AppTheme.prompt_chrome_bg;
            border-width: 1px;
            border-color: AppTheme.prompt_chrome_border;
            border-radius: AppTheme.prompt_chrome_radius;

            VerticalLayout {
                padding: 8px;
                spacing: 4px;

                TextEdit {
                    horizontal-stretch: 1;
                    min-height: 68px;
                    text <=> root.prompt;
                    placeholder-text: root.raw-input-enabled
                        ? "TTY: keys → terminal — @ / Shift+Tab work here; R OFF for line composer + inject"
                        : "Plan, Build, / for commands, @ for context — File / --inject-file for GUI inject";
                    font-size: 13px;
                    wrap: word-wrap;
                    key-pressed(event) => {
                        if (event.modifiers.control && (event.text == "r" || event.text == "R")) {
                            root.raw-input-toggle-requested();
                            accept
                        } else if (event.modifiers.alt && event.text == Key.UpArrow) {
                            root.pty-key-requested(pty_mod(event), "UpArrow");
                            accept
                        } else if (event.modifiers.alt && event.text == Key.DownArrow) {
                            root.pty-key-requested(pty_mod(event), "DownArrow");
                            accept
                        } else if (event.modifiers.alt && event.text == Key.RightArrow) {
                            root.pty-key-requested(pty_mod(event), "RightArrow");
                            accept
                        } else if (event.modifiers.alt && event.text == Key.LeftArrow) {
                            root.pty-key-requested(pty_mod(event), "LeftArrow");
                            accept
                        } else if (!root.raw-input-enabled && (event.text == Key.Return || event.text == "\n" || event.text == "\u{000d}") && !event.modifiers.shift) {
                            root.submit-requested();
                            accept
                        } else if (!root.raw-input-enabled && event.text == Key.UpArrow) {
                            root.history-prev-requested();
                            accept
                        } else if (!root.raw-input-enabled && event.text == Key.DownArrow) {
                            root.history-next-requested();
                            accept
                        } else if (root.raw-input-enabled && (event.text == Key.Return || event.text == "\n" || event.text == "\u{000d}")) {
                            root.pty-key-requested(pty_mod(event), "Return");
                            accept
                        } else if (root.raw-input-enabled && event.text == Key.UpArrow) {
                            root.pty-key-requested(pty_mod(event), "UpArrow");
                            accept
                        } else if (root.raw-input-enabled && event.text == Key.DownArrow) {
                            root.pty-key-requested(pty_mod(event), "DownArrow");
                            accept
                        } else if (root.raw-input-enabled && event.text == Key.RightArrow) {
                            root.pty-key-requested(pty_mod(event), "RightArrow");
                            accept
                        } else if (root.raw-input-enabled && event.text == Key.LeftArrow) {
                            root.pty-key-requested(pty_mod(event), "LeftArrow");
                            accept
                        } else if (root.raw-input-enabled && event.text == Key.Home) {
                            root.pty-key-requested(pty_mod(event), "Home");
                            accept
                        } else if (root.raw-input-enabled && event.text == Key.End) {
                            root.pty-key-requested(pty_mod(event), "End");
                            accept
                        } else if (root.raw-input-enabled && event.text == Key.PageUp) {
                            root.pty-key-requested(pty_mod(event), "PageUp");
                            accept
                        } else if (root.raw-input-enabled && event.text == Key.PageDown) {
                            root.pty-key-requested(pty_mod(event), "PageDown");
                            accept
                        } else if (root.raw-input-enabled && event.text == Key.Delete) {
                            root.pty-key-requested(pty_mod(event), "Delete");
                            accept
                        } else if (root.raw-input-enabled && event.text == Key.Escape) {
                            root.pty-key-requested(pty_mod(event), "Escape");
                            accept
                        } else if (event.modifiers.control && (event.text == "c" || event.text == "C")) {
                            root.pty-key-requested(pty_mod(event), "c");
                            accept
                        } else if (event.text == Key.Tab) {
                            root.pty-key-requested(pty_mod(event), "Tab");
                            accept
                        } else if (root.raw-input-enabled && event.text == Key.Backspace) {
                            root.pty-key-requested(pty_mod(event), "Backspace");
                            accept
                        } else if (root.raw-input-enabled) {
                            root.pty-key-requested(pty_mod(event), event.text);
                            accept
                        } else {
                            reject
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;

                    Rectangle {
                        min-width: 78px;
                        height: 22px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: #00000000;

                        Text {
                            text: "Agent";
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 11px;
                        }
                    }

                    Rectangle {
                        min-width: 54px;
                        height: 22px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: #00000000;

                        Text {
                            text: "Auto";
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 11px;
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        background: #00000000;
                    }

                    Rectangle {
                        min-width: 56px;
                        height: 22px;
                        border-width: 1px;
                        border-color: root.raw-input-enabled ? AppTheme.accent : AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: root.raw-input-enabled ? #ff4f6f : #00000000;

                        Text {
                            text: root.raw-input-enabled ? "R ON" : "R OFF";
                            color: root.raw-input-enabled ? AppTheme.text : AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 10px;
                        }

                        TouchArea {
                            clicked => {
                                root.raw-input-toggle-requested();
                            }
                        }
                    }

                    Rectangle {
                        min-width: 40px;
                        height: 22px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: #00000000;

                        Text {
                            text: "File";
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 11px;
                        }

                        inject_file_ta := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => {
                                root.inject-file-requested();
                            }
                        }
                    }

                    Rectangle {
                        min-width: 36px;
                        height: 22px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: #00000000;

                        Text {
                            text: "Img";
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 11px;
                        }
                    }

                    Rectangle {
                        min-width: 34px;
                        height: 22px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 11px;
                        background: #00000000;

                        Text {
                            text: "Mic";
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 11px;
                        }
                    }

                    Rectangle {
                        width: 34px;
                        height: 22px;
                        border-width: 1px;
                        border-color: AppTheme.accent;
                        border-radius: 11px;
                        background: submit_ta.has-hover ? #ff4f6f : AppTheme.accent;

                        Text {
                            text: "↑";
                            color: AppTheme.text;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 12px;
                            font-weight: 700;
                        }

                        submit_ta := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => {
                                root.submit-requested();
                            }
                        }
                    }
                }
            }
        }
    }
}
