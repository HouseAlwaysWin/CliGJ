import { ScrollView } from "std-widgets.slint";
import { AppTheme } from "../theme.slint";
import { TermLine } from "../term_types.slint";

export component GjViewer inherits Rectangle {
    in property <string> terminal-text;
    in-out property <[TermLine]> terminal-lines;
    in property <bool> auto-scroll: false;
    in property <bool> selection-mode: false;
    in-out property <int> selected-line;
    in-out property <string> selected-context;
    /// Monospace cell width (approx. 13px Cascadia Code; tune if selection drifts).
    private property <length> char-width: 7.8px;
    private property <length> stripe-width: 3px;
    callback selection-committed(int, int, int, int);
    private property <length> terminal-left-inset: 8px;
    private property <length> row-height: 18px;
    private property <bool> drag-active: false;
    private property <bool> has-selection: false;
    private property <int> drag-start-row: 0;
    private property <int> drag-end-row: 0;
    private property <int> drag-start-col: 0;
    private property <int> drag-end-col: 0;
    // Normalized inclusive range (document order).
    private property <bool> sel_forward: root.drag-start-row < root.drag-end-row
        || (root.drag-start-row == root.drag-end-row && root.drag-start-col <= root.drag-end-col);
    private property <int> n_sr: root.sel_forward ? root.drag-start-row : root.drag-end-row;
    private property <int> n_sc: root.sel_forward ? root.drag-start-col : root.drag-end-col;
    private property <int> n_er: root.sel_forward ? root.drag-end-row : root.drag-start-row;
    private property <int> n_ec: root.sel_forward ? root.drag-end-col : root.drag-start-col;

    border-width: 0px;
    background: AppTheme.bg;

    function clamp-row(raw: int) -> int {
        if (root.terminal-lines.length <= 0) {
            0
        } else {
            min(max(raw, 0), root.terminal-lines.length - 1)
        }
    }

    function row-from-y(mouse-y: length) -> int {
        clamp-row((mouse-y - sv.viewport-y) / root.row-height)
    }

    function col-from-x(mouse-x: length, row: int) -> int {
        let len = root.terminal-lines[row].char-count;
        if (len <= 0) {
            return 0;
        }
        let lim = len - 1;
        let c = (mouse-x - root.stripe-width) / root.char-width;
        min(max(c, 0), lim)
    }

    function line_h0(idx: int, line-len: int) -> int {
        if (line-len <= 0) {
            return 0;
        }
        if (idx < root.n_sr || idx > root.n_er) {
            return 0;
        }
        let lim = line-len - 1;
        if (idx == root.n_sr && idx == root.n_er) {
            return min(max(root.n_sc, 0), lim);
        }
        if (idx == root.n_sr) {
            return min(max(root.n_sc, 0), lim);
        }
        return 0;
    }

    function line_h1(idx: int, line-len: int) -> int {
        if (line-len <= 0) {
            return 0;
        }
        if (idx < root.n_sr || idx > root.n_er) {
            return 0;
        }
        let lim = line-len - 1;
        if (idx == root.n_sr && idx == root.n_er) {
            return min(max(root.n_ec, 0), lim);
        }
        if (idx == root.n_sr) {
            return lim;
        }
        if (idx == root.n_er) {
            return min(max(root.n_ec, 0), lim);
        }
        return lim;
    }

    function line_highlight_visible(idx: int, line-len: int) -> bool {
        if (!root.drag-active && !root.has-selection) {
            return false;
        }
        if (root.n_sr == root.n_er && root.n_sc == root.n_ec) {
            return false;
        }
        if (line-len <= 0) {
            return false;
        }
        if (idx < root.n_sr || idx > root.n_er) {
            return false;
        }
        return root.line_h0(idx, line-len) <= root.line_h1(idx, line-len);
    }

    function begin-selection(mx: length, my: length) {
        if (root.terminal-lines.length <= 0) {
            return;
        }
        let row = root.row-from-y(my);
        let col = root.col-from-x(mx, row);
        root.drag-start-row = row;
        root.drag-end-row = row;
        root.drag-start-col = col;
        root.drag-end-col = col;
        root.drag-active = true;
        root.has-selection = true;
        root.selected-line = row;
        root.selected-context = "terminal-selection";
    }

    function update-selection(mx: length, my: length) {
        if (!root.drag-active || root.terminal-lines.length <= 0) {
            return;
        }
        let row = root.row-from-y(my);
        let col = root.col-from-x(mx, row);
        root.drag-end-row = row;
        root.drag-end-col = col;
        root.selected-line = row;
        root.selected-context = "terminal-selection";
    }

    function end-selection() {
        if (!root.drag-active) {
            return;
        }
        root.drag-active = false;
        root.selection-committed(root.n_sr, root.n_sc, root.n_er, root.n_ec);
    }

    public function scroll_to_bottom() {
        if (sv.viewport-height > sv.height) {
            sv.viewport-y = min(0px, sv.height - sv.viewport-height);
        } else {
            sv.viewport-y = 0px;
        }
    }

    public function scroll_to_top() {
        sv.viewport-y = 0px;
    }

    sv := ScrollView {
        visible: true;
        mouse-drag-pan-enabled: false;
        horizontal-scrollbar-policy: always-off;
        vertical-scrollbar-policy: as-needed;
        x: root.terminal-left-inset;
        y: 0px;
        width: max(0px, parent.width - root.terminal-left-inset);
        height: parent.height;
        viewport-width: parent.width;
        viewport-height: content.preferred-height;

        content := VerticalLayout {
            width: parent.width;
            spacing: 0px;
            alignment: start;

            if (root.terminal-lines.length == 0) : Text {
                text: root.terminal-text;
                color: AppTheme.text_muted;
                font-size: 13px;
                font-family: AppTheme.terminal_font_family;
                wrap: no-wrap;
            }

            for line[idx] in root.terminal-lines: HorizontalLayout {
                width: parent.width;
                height: root.row-height;
                spacing: 0px;
                padding: 0px;
                alignment: start;

                Rectangle {
                    width: root.stripe-width;
                    height: root.row-height;
                    background: #00000000;
                }

                Rectangle {
                    horizontal-stretch: 1;
                    height: root.row-height;
                    clip: true;
                    // Full row fill so text spans do not leave grey strips beside short lines.
                    background: AppTheme.bg;

                    property <int> hl0: root.line_h0(idx, line.char-count);
                    property <int> hl1: root.line_h1(idx, line.char-count);
                    property <bool> hl_visible: root.line_highlight_visible(idx, line.char-count);

                    HorizontalLayout {
                        spacing: 0px;
                        padding: 0px;
                        alignment: start;

                        for span in line.spans: Rectangle {
                            background: span.bg;
                            height: root.row-height;

                            Text {
                                text: span.text;
                                color: span.fg;
                                font-size: 13px;
                                font-family: AppTheme.terminal_font_family;
                                wrap: no-wrap;
                                vertical-alignment: center;
                                horizontal-alignment: left;
                            }
                        }
                    }

                    if (hl_visible) : Rectangle {
                        x: hl0 * root.char-width;
                        y: 0px;
                        width: (hl1 - hl0 + 1) * root.char-width;
                        height: root.row-height;
                        // Semi-transparent fill over text (restores readable selection vs outline-only).
                        background: #55a8e8a0;
                    }
                }
            }
        }
    }

    TouchArea {
        z: 100;
        enabled: root.terminal-lines.length > 0;
        x: root.terminal-left-inset;
        y: 0px;
        width: max(0px, parent.width - root.terminal-left-inset);
        height: parent.height;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down && e.button == PointerEventButton.left) {
                root.begin-selection(self.mouse-x, self.mouse-y);
            } else if (e.kind == PointerEventKind.up && e.button == PointerEventButton.left) {
                root.end-selection();
            }
        }
        moved => {
            if (self.pressed) {
                root.update-selection(self.mouse-x, self.mouse-y);
            }
        }
        scroll-event(event) => {
            // Natural wheel: up -> move toward top (viewport-y increases toward 0).
            let next = sv.viewport-y + event.delta-y;
            let max-y = min(0px, sv.height - sv.viewport-height);
            sv.viewport-y = max(max-y, min(0px, next));
            return accept;
        }
    }
}
