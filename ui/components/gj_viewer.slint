import { ScrollView } from "std-widgets.slint";
import { AppTheme } from "../theme.slint";
import { TermLine } from "../term_types.slint";

export component GjViewer inherits Rectangle {
    in property <string> terminal-text;
    in property <string> terminal-font-family: "DejaVu Sans Mono";
    in-out property <[TermLine]> terminal-lines;
    in property <[TermLine]> terminal-pinned-lines: [];
    /// Global index of `terminal-lines[0]` in the full document.
    in property <int> terminal-line-offset: 0;
    /// Full document line count (for scroll extent and selection clamping).
    in property <int> terminal-total-lines: 0;
    in property <bool> auto-scroll: false;
    in property <bool> selection-mode: false;
    in property <bool> raw-input-enabled: false;
    in-out property <int> selected-line;
    in-out property <string> selected-context;
    /// Monospace cell width (approx. 13px Cascadia Code; tune if selection drifts).
    private property <length> char-width: 7.8px;
    private property <length> stripe-width: 3px;
    private property <length> scrollbar-gutter: 14px;
    private property <length> pinned-footer-height: root.terminal-pinned-lines.length * root.row-height;
    callback selection-committed(int, int, int, int);
    callback viewport-changed;
    callback terminal-resize-requested(int, int);
    callback terminal-wheel(int) -> bool;
    callback terminal-context-copy-requested;
    callback terminal-context-clear-requested;
    private property <length> terminal-left-inset: 8px;
    private property <length> row-height: 18px;
    /// 追蹤上次送出的 grid 尺寸，避免每像素 resize 觸發 PTY resize 風暴
    private property <int> last-resize-cols: 0;
    private property <int> last-resize-rows: 0;
    private property <bool> drag-active: false;
    private property <bool> has-selection: false;
    private property <bool> context-menu-open: false;
    private property <length> context-menu-x: 0px;
    private property <length> context-menu-y: 0px;
    private property <int> drag-start-row: 0;
    private property <int> drag-end-row: 0;
    private property <int> drag-start-col: 0;
    private property <int> drag-end-col: 0;
    private property <bool> middle-drag-active: false;
    private property <length> middle-drag-anchor-y: 0px;
    private property <length> middle-drag-current-y: 0px;
    // Normalized inclusive range (document order).
    private property <bool> sel_forward: root.drag-start-row < root.drag-end-row
        || (root.drag-start-row == root.drag-end-row && root.drag-start-col <= root.drag-end-col);
    private property <int> n_sr: root.sel_forward ? root.drag-start-row : root.drag-end-row;
    private property <int> n_sc: root.sel_forward ? root.drag-start-col : root.drag-end-col;
    private property <int> n_er: root.sel_forward ? root.drag-end-row : root.drag-start-row;
    private property <int> n_ec: root.sel_forward ? root.drag-end-col : root.drag-start-col;

    /// For Rust: scroll offset in px (content top), matches `TERMINAL_ROW_HEIGHT` windowing math.
    out property <float> terminal-scroll-top-px: max(0.0, (0.0px - sv.viewport-y) / 1px);
    out property <float> terminal-viewport-height-px: sv.height / 1px;

    border-width: 0px;
    background: AppTheme.bg;

    /// Notifies the PTY of the current grid size (for reflow). Kept in one place so
    /// window resize + explicit bump (e.g. tab switch) stay in sync.
    function sync-terminal-grid-to-pty() {
        let cols = floor((self.width - root.terminal-left-inset - root.stripe-width) / root.char-width);
        let rows = floor(self.height / root.row-height);
        if (cols > 0 && rows > 0
            && (cols != root.last-resize-cols || rows != root.last-resize-rows))
        {
            root.last-resize-cols = cols;
            root.last-resize-rows = rows;
            root.terminal-resize-requested(cols, rows);
        }
    }

    changed width => {
        root.sync-terminal-grid-to-pty();
    }

    changed height => {
        root.sync-terminal-grid-to-pty();
    }

    /// 分頁載入時呼叫：強制送出 resize，忽略去抖。
    /// 新分頁的 PTY 可能還在 120×40，必須確保 resize 到實際 viewer 尺寸。
    public function bump-terminal-size() {
        let cols = floor((self.width - root.terminal-left-inset - root.stripe-width) / root.char-width);
        let rows = floor(self.height / root.row-height);
        if (cols > 0 && rows > 0) {
            root.last-resize-cols = cols;
            root.last-resize-rows = rows;
            root.terminal-resize-requested(cols, rows);
        }
    }

    function clamp-row(raw: int) -> int {
        if (root.terminal-total-lines <= 0) {
            0
        } else {
            min(max(raw, 0), root.terminal-total-lines - 1)
        }
    }

    /// Global document row from mouse Y.
    function row-from-y(mouse-y: length) -> int {
        clamp-row(floor((mouse-y - sv.viewport-y) / root.row-height))
    }

    function col-from-x(mx: length, global-row: int) -> int {
        let local = global-row - root.terminal-line-offset;
        if (local < 0 || local >= root.terminal-lines.length) {
            return 0;
        }
        let len = root.terminal-lines[local].char-count;
        if (len <= 0) {
            return 0;
        }
        let lim = len - 1;
        let c = floor((mx - root.stripe-width) / root.char-width);
        min(max(c, 0), lim)
    }

    function line_h0(global-idx: int, line-len: int) -> int {
        if (line-len <= 0) {
            return 0;
        }
        if (global-idx < root.n_sr || global-idx > root.n_er) {
            return 0;
        }
        let lim = line-len - 1;
        if (global-idx == root.n_sr && global-idx == root.n_er) {
            return min(max(root.n_sc, 0), lim);
        }
        if (global-idx == root.n_sr) {
            return min(max(root.n_sc, 0), lim);
        }
        return 0;
    }

    function line_h1(global-idx: int, line-len: int) -> int {
        if (line-len <= 0) {
            return 0;
        }
        if (global-idx < root.n_sr || global-idx > root.n_er) {
            return 0;
        }
        let lim = line-len - 1;
        if (global-idx == root.n_sr && global-idx == root.n_er) {
            return min(max(root.n_ec, 0), lim);
        }
        if (global-idx == root.n_sr) {
            return lim;
        }
        if (global-idx == root.n_er) {
            return min(max(root.n_ec, 0), lim);
        }
        return lim;
    }

    function line_highlight_visible(global-idx: int, line-len: int) -> bool {
        if (!root.drag-active && !root.has-selection) {
            return false;
        }
        if (root.n_sr == root.n_er && root.n_sc == root.n_ec) {
            return false;
        }
        if (line-len <= 0) {
            return false;
        }
        if (global-idx < root.n_sr || global-idx > root.n_er) {
            return false;
        }
        return root.line_h0(global-idx, line-len) <= root.line_h1(global-idx, line-len);
    }

    function begin-selection(mx: length, my: length) {
        if (root.terminal-total-lines <= 0) {
            return;
        }
        let row = root.row-from-y(my);
        let col = root.col-from-x(mx, row);
        root.drag-start-row = row;
        root.drag-end-row = row;
        root.drag-start-col = col;
        root.drag-end-col = col;
        root.drag-active = true;
        root.has-selection = true;
        root.selected-line = row;
        root.selected-context = "terminal-selection";
    }

    function update-selection(mx: length, my: length) {
        if (!root.drag-active || root.terminal-total-lines <= 0) {
            return;
        }
        let row = root.row-from-y(my);
        let col = root.col-from-x(mx, row);
        root.drag-end-row = row;
        root.drag-end-col = col;
        root.selected-line = row;
        root.selected-context = "terminal-selection";
    }

    function end-selection() {
        if (!root.drag-active) {
            return;
        }
        root.drag-active = false;
        root.selection-committed(root.n_sr, root.n_sc, root.n_er, root.n_ec);
    }

    public function scroll_to_bottom() {
        if (root.terminal-total-lines * root.row-height > sv.height) {
            sv.viewport-y = sv.height - (root.terminal-total-lines * root.row-height);
        } else {
            sv.viewport-y = 0px;
        }
        root.viewport-changed();
    }

    public function scroll_to_top() {
        sv.viewport-y = 0px;
        root.viewport-changed();
    }

    /// Set content scroll offset in px (matches `terminal-scroll-top-px`). Clamps to the valid range.
    /// Rust 呼叫此函式後一定會緊接 push_terminal_view_to_ui，不需再觸發延遲 viewport-changed。
    public function apply_scroll_top_px(top_px: float) {
        let ch: length = max(root.row-height, root.terminal-total-lines * root.row-height);
        let max_scroll: float = max(0.0, (ch / 1px) - (sv.height / 1px));
        let t: float = min(max(top_px, 0.0), max_scroll);
        sv.viewport-y = -(t * 1px);
    }

    // Auto-scroll is driven from Rust (`refresh_current_terminal`) so it stays in sync with
    // windowing math. A Slint `changed terminal-total-lines` handler here fought that logic
    // and caused races (blank terminal / flicker on new tabs).

    sv := ScrollView {
        visible: true;
        mouse-drag-pan-enabled: true;
        horizontal-scrollbar-policy: always-off;
        vertical-scrollbar-policy: always-on;
        x: root.terminal-left-inset;
        y: 0px;
        width: max(0px, parent.width - root.terminal-left-inset);
        height: max(0px, parent.height - root.pinned-footer-height);
        viewport-width: parent.width;
        viewport-height: max(root.row-height, root.terminal-total-lines * root.row-height);

        changed viewport-y => {
            root.viewport-changed();
        }

        content := Rectangle {
            width: parent.width;
            height: parent.viewport-height;

            if (root.terminal-total-lines == 0) : Text {
                x: 0px;
                y: 0px;
                width: parent.width;
                text: root.terminal-text;
                color: AppTheme.text_muted;
                font-size: 13px;
                font-family: root.terminal-font-family;
                wrap: word-wrap;
            }

            for line[idx] in root.terminal-lines: Rectangle {
                x: 0px;
                y: (root.terminal-line-offset + idx) * root.row-height;
                width: parent.width;
                height: root.row-height;
                background: AppTheme.bg; // Move background to row level to avoid layout gaps

                // Stripe (Absolute positioned)
                Rectangle {
                    x: 0px;
                    y: 0px;
                    width: root.stripe-width;
                    height: parent.height;
                    background: #00000000;
                }

                // Content (Absolute positioned)
                Rectangle {
                    x: root.stripe-width;
                    y: 0px;
                    width: parent.width - root.stripe-width;
                    height: parent.height;
                    clip: true;

                    property <int> gidx: root.terminal-line-offset + idx;
                    property <int> hl0: root.line_h0(gidx, line.char-count);
                    property <int> hl1: root.line_h1(gidx, line.char-count);
                    property <bool> hl_visible: root.line_highlight_visible(gidx, line.char-count);

                    // We still use HorizontalLayout for spans as they have dynamic width, 
                    // but it's now flatter.
                    HorizontalLayout {
                        spacing: 0px;
                        padding: 0px;
                        alignment: start;

                        for span in line.spans: Rectangle {
                            background: span.bg;
                            height: root.row-height;

                            Text {
                                text: span.text;
                                color: span.fg;
                                font-size: 13px;
                                font-family: span.font-family == "" ? root.terminal-font-family : span.font-family;
                                wrap: no-wrap;
                                vertical-alignment: center;
                                horizontal-alignment: left;
                            }
                        }
                    }

                    if (hl_visible) : Rectangle {
                        x: hl0 * root.char-width;
                        y: 0px;
                        width: (hl1 - hl0 + 1) * root.char-width;
                        height: root.row-height;
                        background: #55a8e8a0;
                    }
                }
            }
        }
    }

    if (root.terminal-pinned-lines.length > 0) : Rectangle {
        x: root.terminal-left-inset;
        y: sv.height;
        width: max(0px, parent.width - root.terminal-left-inset - root.scrollbar-gutter);
        height: root.pinned-footer-height;
        background: AppTheme.bg;
        clip: true;

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 1px;
            background: AppTheme.tab_separator;
        }

        for line[idx] in root.terminal-pinned-lines: Rectangle {
            x: 0px;
            y: idx * root.row-height;
            width: parent.width;
            height: root.row-height;
            background: AppTheme.bg;

            Rectangle {
                x: 0px;
                y: 0px;
                width: root.stripe-width;
                height: parent.height;
                background: #00000000;
            }

            Rectangle {
                x: root.stripe-width;
                y: 0px;
                width: parent.width - root.stripe-width;
                height: parent.height;
                clip: true;

                HorizontalLayout {
                    spacing: 0px;
                    padding: 0px;
                    alignment: start;

                    for span in line.spans: Rectangle {
                        background: span.bg;
                        height: root.row-height;

                        Text {
                            text: span.text;
                            color: span.fg;
                            font-size: 13px;
                            font-family: span.font-family == "" ? root.terminal-font-family : span.font-family;
                            wrap: no-wrap;
                            vertical-alignment: center;
                            horizontal-alignment: left;
                        }
                    }
                }
            }
        }
    }

    // Wheel layer: always active for terminal scrolling / interactive follow.
    TouchArea {
        z: 100;
        enabled: root.terminal-total-lines > 0;
        x: root.terminal-left-inset;
        y: 0px;
        width: max(0px, parent.width - root.terminal-left-inset - root.scrollbar-gutter);
        height: parent.height;
        scroll-event(event) => {
            if (root.terminal-wheel(event.delta-y / 1px)) {
                return accept;
            }
            // Natural wheel: up -> move toward top (viewport-y increases toward 0).
            let next = sv.viewport-y + event.delta-y;
            let max-y = min(0px, sv.height - sv.viewport-height);
            sv.viewport-y = max(max-y, min(0px, next));
            return accept;
        }
    }

    // Unified pointer layer for terminal interactions. Keep middle-click autoscroll, left-drag
    // selection, and right-click context menu on one TouchArea so a higher transparent layer
    // cannot swallow selection drags before they reach the hit-testing logic below.
    TouchArea {
        z: 101;
        enabled: root.terminal-total-lines > 0;
        x: root.terminal-left-inset;
        y: 0px;
        width: max(0px, parent.width - root.terminal-left-inset - root.scrollbar-gutter);
        height: parent.height;
        mouse-cursor: root.middle-drag-active ? MouseCursor.move : MouseCursor.default;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down && e.button == PointerEventButton.middle) {
                root.context-menu-open = false;
                root.middle-drag-active = true;
                root.middle-drag-anchor-y = self.mouse-y;
                root.middle-drag-current-y = self.mouse-y;
            } else if (e.kind == PointerEventKind.up && e.button == PointerEventButton.middle) {
                root.middle-drag-active = false;
            } else if (e.kind == PointerEventKind.down && e.button == PointerEventButton.left) {
                root.context-menu-open = false;
                root.begin-selection(self.mouse-x, self.mouse-y);
            } else if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                root.context-menu-x = min(self.mouse-x, max(0px, self.width - 134px));
                root.context-menu-y = min(self.mouse-y, max(0px, self.height - 66px));
                root.context-menu-open = true;
            } else if (e.kind == PointerEventKind.up && e.button == PointerEventButton.left) {
                root.end-selection();
            }
        }
        moved => {
            if (root.middle-drag-active) {
                let delta = self.mouse-y - root.middle-drag-current-y;
                root.middle-drag-current-y = self.mouse-y;

                // Scrolling down (mouse moves down, delta > 0) should decrease viewport-y.
                let next = sv.viewport-y - delta;
                let max-y = min(0px, sv.height - sv.viewport-height);
                sv.viewport-y = max(max-y, min(0px, next));
            } else if (root.drag-active) {
                root.update-selection(self.mouse-x, self.mouse-y);
            }
        }
    }

    if (root.context-menu-open) : Rectangle {
        z: 140;
        x: root.terminal-left-inset + root.context-menu-x;
        y: root.context-menu-y;
        width: 132px;
        height: 64px;
        border-width: 1px;
        border-color: AppTheme.prompt_chrome_border;
        border-radius: 6px;
        background: #1a1d24;

        VerticalLayout {
            padding: 4px;
            spacing: 2px;

            Rectangle {
                height: 26px;
                border-radius: 4px;
                background: copy_ta.has-hover ? #2b2d33 : #00000000;

                Text {
                    text: @tr("複製");
                    color: AppTheme.text;
                    vertical-alignment: center;
                    x: 10px;
                    width: parent.width - 10px;
                    height: parent.height;
                }

                copy_ta := TouchArea {
                    clicked => {
                        root.context-menu-open = false;
                        root.terminal-context-copy-requested();
                    }
                }
            }

            Rectangle {
                height: 26px;
                border-radius: 4px;
                background: clear_ta.has-hover ? #2b2d33 : #00000000;

                Text {
                    text: @tr("清除畫面");
                    color: AppTheme.text;
                    vertical-alignment: center;
                    x: 10px;
                    width: parent.width - 10px;
                    height: parent.height;
                }

                clear_ta := TouchArea {
                    clicked => {
                        root.context-menu-open = false;
                        root.terminal-context-clear-requested();
                    }
                }
            }
        }
    }

    if (root.context-menu-open) : TouchArea {
        z: 130;
        x: root.terminal-left-inset;
        y: 0px;
        width: max(0px, parent.width - root.terminal-left-inset - root.scrollbar-gutter);
        height: parent.height;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down && e.button == PointerEventButton.left) {
                root.context-menu-open = false;
            }
        }
    }

    if (root.middle-drag-active) : Rectangle {
        z: 200;
        x: root.terminal-left-inset + (root.width - root.terminal-left-inset - root.scrollbar-gutter - 24px) / 2;
        y: root.middle-drag-anchor-y - 12px;
        width: 24px;
        height: 24px;
        border-radius: 12px;
        background: #ffffff40;
        border-width: 1px;
        border-color: #ffffff80;
        
        // Simple cross/arrow indicator
        Rectangle { width: 2px; height: 14px; background: white; x: 11px; y: 5px; }
        Rectangle { width: 14px; height: 2px; background: white; x: 5px; y: 11px; }
    }
}
