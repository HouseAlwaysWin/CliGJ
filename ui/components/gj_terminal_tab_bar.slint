import { ScrollView } from "std-widgets.slint";
import { AppTheme } from "../theme.slint";
import { GjTerminalTab } from "gj_terminal_tab.slint";

export component GjTerminalTabBar inherits Rectangle {
    in property <[string]> tab-titles;
    in property <int> tab-count;
    in property <int> current-tab;
    callback select-tab(int);
    callback close-tab(int);
    callback new-tab-requested;

    property <length> plus-w: 36px;
    property <length> left-pad: 4px;
    property <length> right-pad: 4px;
    property <length> tabs-content-width: root.tab-count * AppTheme.tab_width;
    property <length> plus-fixed-x: root.width - root.plus-w - root.right-pad;
    // "+" follows tab edge initially, then pins right when tabs overflow.
    property <length> plus-x: min(root.left-pad + root.tabs-content-width, root.plus-fixed-x);
    // Tab viewport fills from left edge to "+".
    property <length> tab-viewport-width: max(0px, root.plus-x - root.left-pad);

    height: AppTheme.tab_bar_height;
    background: AppTheme.tab_bar_bg;
    border-width: 0px;

    function pan-tabs(delta-x: length, delta-y: length) -> EventResult {
        let max-scroll = scroll-view.viewport-width - scroll-view.visible-width;
        if (max-scroll <= 0px) {
            return reject;
        }
        // Map vertical wheel to horizontal pan to support normal mouse wheel.
        let next = scroll-view.viewport-x - delta-y - delta-x;
        scroll-view.viewport-x = max(-max-scroll, min(0px, next));
        return accept;
    }

    // Left tab viewport (absolute geometry to avoid layout binding loops).
    Rectangle {
        x: root.left-pad;
        y: 0px;
        width: root.tab-viewport-width;
        height: root.height;
        background: #00000000;

        tab-strip := TouchArea {
            width: parent.width;
            height: parent.height;

            scroll-view := ScrollView {
                width: parent.width;
                height: parent.height;
                viewport-width: root.tabs-content-width;
                viewport-height: parent.height;
                horizontal-scrollbar-policy: always-off;
                vertical-scrollbar-policy: always-off;
                mouse-drag-pan-enabled: true;

                Rectangle {
                    width: root.tab-count * AppTheme.tab_width;
                    height: parent.height;
                    background: #00000000;

                    for title[index] in root.tab-titles: GjTerminalTab {
                        x: index * AppTheme.tab_width;
                        y: 0px;
                        width: AppTheme.tab_width;
                        height: parent.height;
                        title: title;
                        active: root.current-tab == index;
                        pressed => {
                            root.select-tab(index);
                        }
                        close-requested => {
                            root.close-tab(index);
                        }
                        scroll-requested(dx, dy) => {
                            root.pan-tabs(dx, dy);
                        }
                    }
                }
            }

            scroll-event(event) => {
                return root.pan-tabs(event.delta-x, event.delta-y);
            }
        }
    }

    // "+" follows tabs until overflow, then stays pinned right.
    Rectangle {
        x: root.plus-x;
        y: 0px;
        width: root.plus-w;
        height: root.height;
        background: #00000000;

        Text {
            text: "+";
            color: AppTheme.text_muted;
            horizontal-alignment: center;
            vertical-alignment: center;
            font-size: 18px;
            font-weight: 500;
        }

        TouchArea {
            clicked => {
                root.new-tab-requested();
            }
        }
    }

    Rectangle {
        y: parent.height - 1px;
        height: 1px;
        width: parent.width;
        background: #3c3c3c;
    }
}
