import { ScrollView } from "std-widgets.slint";
import { AppTheme } from "../theme.slint";
import { GjTerminalTab } from "gj_terminal_tab.slint";

export component GjTerminalTabBar inherits Rectangle {
    in property <[string]> tab-titles;
    in property <int> tab-count;
    in property <int> current-tab;
    in-out property <string> current-cmd-type: "Command Prompt";
    in property <[string]> cmd-type-choices: ["Command Prompt", "PowerShell"];
    callback select-tab(int);
    callback close-tab(int);
    callback new-tab-requested;
    callback cmd-type-selected(string);
    callback manage-cmd-types-requested;
    callback rename-tab(int);
    callback move-tab(int, int);

    property <length> plus-w: 32px;
    property <length> cmd-picker-w: 32px;
    property <length> left-pad: 4px;
    property <length> right-pad: 4px;
    property <length> bar-h: AppTheme.tab_bar_height;
    property <length> tabs-content-width: root.tab-count * AppTheme.tab_width;
    property <length> plus-fixed-x: root.width - root.plus-w - root.cmd-picker-w - root.right-pad;
    // "+" follows tab edge initially, then pins right when tabs overflow.
    property <length> plus-x: min(root.left-pad + root.tabs-content-width, root.plus-fixed-x);
    property <length> cmd-picker-x: root.plus-x + root.plus-w;
    // Tab viewport fills from left edge to "+".
    property <length> tab-viewport-width: max(0px, root.plus-x - root.left-pad);
    property <bool> cmd-menu-open: false;
    property <bool> dragging: false;
    property <int> drag-index: -1;

    height: root.bar-h;
    background: AppTheme.tab_bar_bg;
    border-width: 0px;

    function pan-tabs(delta-x: length, delta-y: length) -> EventResult {
        let max-scroll = scroll-view.viewport-width - scroll-view.visible-width;
        if (max-scroll <= 0px) {
            return reject;
        }
        // Map vertical wheel to horizontal pan to support normal mouse wheel.
        let next = scroll-view.viewport-x - delta-y - delta-x;
        scroll-view.viewport-x = max(-max-scroll, min(0px, next));
        return accept;
    }

    function clamp_index(i: int) -> int {
        if (i < 0) { return 0; }
        if (i >= root.tab-count) { return root.tab-count - 1; }
        return i;
    }

    function maybe_reorder_tabs(x: length) {
        if (!root.dragging || root.drag-index < 0) { return; }
        // Convert from bar-local x to scroll-view content x.
        let content_x = (-scroll-view.viewport-x) + (x - root.left-pad);
        // length/length => float; implicit float->int conversion truncates.
        let idx = clamp_index(content_x / AppTheme.tab_width);
        if (idx != root.drag-index) {
            root.move-tab(root.drag-index, idx);
            root.drag-index = idx;
        }
    }

    // Left tab viewport (absolute geometry to avoid layout binding loops).
    Rectangle {
        x: root.left-pad;
        y: 0px;
        width: root.tab-viewport-width;
        height: root.bar-h;
        background: #00000000;

        tab-strip := TouchArea {
            width: parent.width;
            height: parent.height;

            scroll-view := ScrollView {
                width: parent.width;
                height: parent.height;
                viewport-width: root.tabs-content-width;
                viewport-height: parent.height;
                horizontal-scrollbar-policy: always-off;
                vertical-scrollbar-policy: always-off;
                mouse-drag-pan-enabled: true;

                Rectangle {
                    width: root.tab-count * AppTheme.tab_width;
                    height: parent.height;
                    background: #00000000;

                    for title[index] in root.tab-titles: GjTerminalTab {
                        x: index * AppTheme.tab_width;
                        y: 0px;
                        width: AppTheme.tab_width;
                        height: parent.height;
                        title: title;
                        active: root.current-tab == index;
                        pressed => {
                            root.select-tab(index);
                        }
                        rename-requested => {
                            root.rename-tab(index);
                        }
                        close-requested => {
                            root.close-tab(index);
                        }
                        drag-started(x) => {
                            root.dragging = true;
                            root.drag-index = index;
                            root.maybe_reorder_tabs(x);
                        }
                        drag-moved(x) => {
                            root.maybe_reorder_tabs(x);
                        }
                        drag-ended => {
                            root.dragging = false;
                            root.drag-index = -1;
                        }
                        scroll-requested(dx, dy) => {
                            root.pan-tabs(dx, dy);
                        }
                    }
                }
            }

            scroll-event(event) => {
                return root.pan-tabs(event.delta-x, event.delta-y);
            }
        }
    }

    // "+" follows tabs until overflow, then stays pinned right.
    Rectangle {
        x: root.plus-x;
        y: 0px;
        width: root.plus-w;
        height: root.bar-h;
        background: plus_ta.has-hover ? #2d2d30 : #00000000;

        Text {
            text: "+";
            color: AppTheme.text_muted;
            horizontal-alignment: center;
            vertical-alignment: center;
            font-size: 16px;
            font-weight: 500;
        }

        plus_ta := TouchArea {
            clicked => {
                root.cmd-menu-open = false;
                root.new-tab-requested();
            }
        }
    }

    // Command type picker button (dropdown trigger).
    Rectangle {
        x: root.cmd-picker-x;
        y: 0px;
        width: root.cmd-picker-w;
        height: root.bar-h;
        background: picker_ta.has-hover ? #2d2d30 : #00000000;

        Path {
            x: (parent.width - 10px) / 2;
            y: (parent.height - 6px) / 2;
            width: 10px;
            height: 6px;
            viewbox-x: 0;
            viewbox-y: 0;
            viewbox-width: 10;
            viewbox-height: 6;
            fill: #00000000;
            stroke: AppTheme.text_muted;
            stroke-width: 1.6px;
            stroke-line-cap: round;
            stroke-line-join: round;
            commands: root.cmd-menu-open ? "M 1 5 L 5 1 L 9 5" : "M 1 1 L 5 5 L 9 1";
        }

        picker_ta := TouchArea {
            clicked => {
                root.cmd-menu-open = !root.cmd-menu-open;
            }
        }
    }

    if root.cmd-menu-open : Rectangle {
        x: max(root.left-pad, root.cmd-picker-x - 170px);
        y: root.bar-h + 2px;
        width: 198px;
        height: min(230px, 14px + root.cmd-type-choices.length * 28px + 34px);
        background: AppTheme.panel_alt;
        border-width: 1px;
        border-color: AppTheme.prompt_chrome_border;
        border-radius: 8px;
        z: 10;

        VerticalLayout {
            padding: 6px;
            spacing: 4px;

            ScrollView {
                vertical-stretch: 1;
                horizontal-scrollbar-policy: always-off;
                vertical-scrollbar-policy: as-needed;
                min-height: 0px;

                VerticalLayout {
                    spacing: 2px;
                    alignment: start;

                    for item in root.cmd-type-choices: Rectangle {
                        height: 24px;
                        border-radius: 6px;
                        background: (root.current-cmd-type == item || item_ta.has-hover) ? #2d2d30 : #00000000;
                        Text {
                            text: item;
                            color: AppTheme.text;
                            vertical-alignment: center;
                            horizontal-alignment: left;
                            x: 8px;
                            width: parent.width - 12px;
                            font-size: 12px;
                            overflow: elide;
                        }
                        item_ta := TouchArea {
                            clicked => {
                                root.current-cmd-type = item;
                                root.cmd-menu-open = false;
                                root.cmd-type-selected(item);
                            }
                        }
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: AppTheme.prompt_chrome_border;
            }

            Rectangle {
                height: 24px;
                border-radius: 6px;
                background: manage_ta.has-hover ? #2d2d30 : #00000000;
                Text {
                    text: @tr("設定");
                    color: AppTheme.text;
                    vertical-alignment: center;
                    horizontal-alignment: left;
                    x: 8px;
                    width: parent.width - 12px;
                    font-size: 12px;
                }
                manage_ta := TouchArea {
                    clicked => {
                        root.cmd-menu-open = false;
                        root.manage-cmd-types-requested();
                    }
                }
            }
        }
    }

    Rectangle {
        y: root.bar-h - 1px;
        height: 1px;
        width: parent.width;
        background: #3c3c3c;
    }
}
