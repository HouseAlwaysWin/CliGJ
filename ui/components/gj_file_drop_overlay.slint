import { AppTheme } from "../theme.slint";

export component GjFileDropOverlay inherits Rectangle {
    width: 100%;
    height: 100%;
    background: #1a1b26c0;
    z: 500;

    Rectangle {
        width: 240px;
        height: 120px;
        border-width: 2px;
        border-color: AppTheme.accent;
        border-radius: 12px;
        background: AppTheme.bg;

        VerticalLayout {
            alignment: center;
            spacing: 12px;
            Text {
                // ASCII "+" — U+2295 (⊕) is often missing from bundled UI fonts and renders as tofu.
                text: "+";
                font-size: 32px;
                font-weight: 300;
                color: AppTheme.accent;
                horizontal-alignment: center;
            }
            Text {
                text: @tr("放開以加入檔案");
                font-size: 16px;
                font-weight: 600;
                color: AppTheme.text;
                horizontal-alignment: center;
            }
        }
    }
}
