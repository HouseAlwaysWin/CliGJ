import { AppTheme } from "../theme.slint";
import { GjChromeButton } from "gj_chrome_button.slint";
import { TextEdit } from "std-widgets.slint";

export component GjRenameTabDialog inherits Rectangle {
    width: 100%;
    height: 100%;
    background: #00000080;
    z: 100;

    in-out property <string> rename-text;
    in property <int> rename-index;

    callback rename-commit(int, string);
    callback rename-cancel;

    Rectangle {
        width: 360px * AppTheme.ui_zoom_factor;
        height: 140px * AppTheme.ui_zoom_factor;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: AppTheme.panel;
        border-width: 1px;
        border-color: AppTheme.prompt_chrome_border;
        border-radius: 10px;

        VerticalLayout {
            padding: 12px;
            spacing: 10px;

            Text {
                text: @tr("重新命名標籤");
                color: AppTheme.text;
                font-size: 13px * AppTheme.ui_zoom_factor;
                font-weight: 600;
            }

            TextEdit {
                text <=> root.rename-text;
                font-size: 13px * AppTheme.ui_zoom_factor;
                wrap: no-wrap;
                key-pressed(event) => {
                    if (event.text == Key.Return) {
                        root.rename-commit(root.rename-index, root.rename-text);
                        accept
                    } else if (event.text == Key.Escape) {
                        root.rename-cancel();
                        accept
                    } else {
                        reject
                    }
                }
            }

            HorizontalLayout {
                spacing: 8px;
                Rectangle { horizontal-stretch: 1; background: #00000000; }

                GjChromeButton {
                    label: @tr("取消");
                    min-button-width: 72px;
                    button-height: 28px;
                    preset: "close";
                    clicked => {
                        root.rename-cancel();
                    }
                }

                GjChromeButton {
                    label: @tr("確定");
                    min-button-width: 72px;
                    button-height: 28px;
                    preset: "save";
                    clicked => {
                        root.rename-commit(root.rename-index, root.rename-text);
                    }
                }
            }
        }
    }
}
