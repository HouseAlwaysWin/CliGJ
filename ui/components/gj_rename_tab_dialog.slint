import { AppTheme } from "../theme.slint";
import { TextEdit } from "std-widgets.slint";

export component GjRenameTabDialog inherits Rectangle {
    width: 100%;
    height: 100%;
    background: #00000080;
    z: 100;

    in-out property <string> rename-text;
    in property <int> rename-index;

    callback rename-commit(int, string);
    callback rename-cancel;

    Rectangle {
        width: 360px;
        height: 140px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: AppTheme.panel;
        border-width: 1px;
        border-color: AppTheme.prompt_chrome_border;
        border-radius: 10px;

        VerticalLayout {
            padding: 12px;
            spacing: 10px;

            Text {
                text: @tr("重新命名標籤");
                color: AppTheme.text;
                font-size: 13px;
                font-weight: 600;
            }

            TextEdit {
                text <=> root.rename-text;
                font-size: 13px;
                wrap: no-wrap;
                key-pressed(event) => {
                    if (event.text == Key.Return) {
                        root.rename-commit(root.rename-index, root.rename-text);
                        accept
                    } else if (event.text == Key.Escape) {
                        root.rename-cancel();
                        accept
                    } else {
                        reject
                    }
                }
            }

            HorizontalLayout {
                spacing: 8px;
                Rectangle { horizontal-stretch: 1; background: #00000000; }

                Rectangle {
                    min-width: 72px;
                    height: 28px;
                    border-width: 1px;
                    border-color: AppTheme.prompt_chrome_border;
                    border-radius: 8px;
                    background: #00000000;
                    Text {
                        text: @tr("取消");
                        color: AppTheme.text_muted;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: 12px;
                    }
                    TouchArea {
                        clicked => { root.rename-cancel(); }
                    }
                }

                Rectangle {
                    min-width: 72px;
                    height: 28px;
                    border-width: 1px;
                    border-color: AppTheme.accent;
                    border-radius: 8px;
                    background: AppTheme.accent;
                    Text {
                        text: @tr("確定");
                        color: AppTheme.text;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: 12px;
                        font-weight: 700;
                    }
                    TouchArea {
                        clicked => { root.rename-commit(root.rename-index, root.rename-text); }
                    }
                }
            }
        }
    }
}
