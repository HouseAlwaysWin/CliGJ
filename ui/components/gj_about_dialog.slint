import { AppTheme } from "../theme.slint";
import { GjChromeButton } from "gj_chrome_button.slint";

export component GjAboutDialog inherits Rectangle {
    // Avoid relative `%` sizing in standalone component analysis; real size is set by `app.slint`.
    preferred-width: 800px;
    preferred-height: 600px;
    z: 40;
    background: #00000099;

    in-out property <string> version: "";
    in-out property <string> author: "";
    in-out property <string> github-url: "";

    callback close-requested;
    callback open-github-requested(string);

    TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        clicked => {
            root.close-requested();
        }
    }

    Rectangle {
        width: min(parent.width - 32px, 430px);
        height: min(parent.height - 32px, 210px);
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: AppTheme.panel_alt;
        border-width: 1px;
        border-color: AppTheme.prompt_chrome_border;
        border-radius: 12px;

        VerticalLayout {
            padding: 16px;
            spacing: 10px;
            alignment: start;

            HorizontalLayout {
                spacing: 10px;
                alignment: start;

                Image {
                    source: @image-url("../../src/asset/logo3.png");
                    width: 44px;
                    height: 44px;
                }

                VerticalLayout {
                    spacing: 2px;
                    Text {
                        text: "CliGJ";
                        color: AppTheme.text;
                        font-size: 18px;
                        font-weight: 700;
                    }
                    Text {
                        text: @tr("版本：") + root.version + "  |  " + @tr("作者：") + root.author;
                        color: AppTheme.text_muted;
                        font-size: 12px;
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: AppTheme.prompt_chrome_border;
            }

            Text {
                text: @tr("GitHub");
                color: AppTheme.text;
                font-size: 13px;
                font-weight: 600;
            }

            Rectangle {
                min-height: 32px;
                background: #00000000;

                Text {
                    text: root.github-url;
                    color: AppTheme.accent;
                    horizontal-alignment: left;
                    vertical-alignment: center;
                    x: 0px;
                    width: parent.width;
                    font-size: 12px;
                    overflow: elide;
                }

                TouchArea {
                    clicked => {
                        root.open-github-requested(root.github-url);
                    }
                }
            }

            HorizontalLayout {
                Rectangle {
                    horizontal-stretch: 1;
                    background: #00000000;
                }
                GjChromeButton {
                    label: @tr("關閉");
                    min-button-width: 72px;
                    button-height: 30px;
                    pill-corner-radius: 15px;
                    preset: "close";
                    clicked => {
                        root.close-requested();
                    }
                }
            }
        }
    }
}
