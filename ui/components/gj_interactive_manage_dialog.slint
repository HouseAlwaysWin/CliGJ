import { AppTheme } from "../theme.slint";
import { InteractiveCmdEditorRow } from "../term_types.slint";
import { LineEdit, ScrollView } from "std-widgets.slint";

export component GjInteractiveManageDialog inherits Rectangle {
    width: 100%;
    height: 100%;
    background: #00000080;
    z: 106;

    in-out property <[InteractiveCmdEditorRow]> manage-rows;

    callback manage-add-row;
    callback remove-row(int);
    callback name-edited(int, string);
    callback line-edited(int, string);
    callback save;
    callback close;

    Rectangle {
        width: 560px;
        height: 420px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: AppTheme.panel;
        border-width: 1px;
        border-color: AppTheme.prompt_chrome_border;
        border-radius: 10px;

        VerticalLayout {
            padding: 12px;
            spacing: 8px;

            Text {
                text: @tr("指令設定");
                color: AppTheme.text;
                font-size: 13px;
                font-weight: 600;
            }

            Text {
                text: @tr("內建 Gemini / Codex / Claude / Copilot 無法刪除；變更後請按儲存。");
                color: AppTheme.text_muted;
                font-size: 11px;
                wrap: word-wrap;
            }

            HorizontalLayout {
                spacing: 8px;
                alignment: end;

                Rectangle {
                    min-width: 64px;
                    height: 26px;
                    horizontal-stretch: 0;
                    border-width: 1px;
                    border-color: AppTheme.prompt_chrome_border;
                    border-radius: 8px;
                    background: #00000000;

                    Text {
                        text: @tr("新增");
                        color: AppTheme.text;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: 12px;
                        font-weight: 600;
                    }

                    TouchArea {
                        clicked => {
                            root.manage-add-row();
                        }
                    }
                }
            }

            ScrollView {
                vertical-stretch: 1;
                min-height: 0px;

                VerticalLayout {
                    alignment: start;
                    spacing: 6px;

                    for row[key_idx] in root.manage-rows: Rectangle {
                        min-height: 32px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 6px;
                        background: #00000000;

                        HorizontalLayout {
                            padding-left: 6px;
                            padding-right: 6px;
                            spacing: 6px;
                            alignment: center;

                            if row.key-locked: Rectangle {
                                horizontal-stretch: 1;
                                min-width: 96px;
                                min-height: 26px;
                                background: #00000020;
                                border-radius: 4px;

                                Text {
                                    text: row.name;
                                    color: AppTheme.text_muted;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    horizontal-alignment: left;
                                    overflow: elide;
                                }
                            }

                            if !row.key-locked: LineEdit {
                                horizontal-stretch: 1;
                                min-width: 96px;
                                font-size: 12px;
                                text: row.name;
                                edited(new_text) => {
                                    root.name-edited(key_idx, new_text);
                                }
                            }

                            Text {
                                text: ">";
                                color: AppTheme.text_muted;
                                font-size: 12px;
                                vertical-alignment: center;
                                horizontal-stretch: 0;
                            }

                            LineEdit {
                                horizontal-stretch: 2;
                                min-width: 140px;
                                font-size: 12px;
                                text: row.line;
                                edited(new_text) => {
                                    root.line-edited(key_idx, new_text);
                                }
                            }

                            Rectangle {
                                min-width: 44px;
                                max-width: 52px;
                                height: 24px;
                                horizontal-stretch: 0;
                                border-width: 1px;
                                border-color: #ff4f6d;
                                border-radius: 6px;
                                background: #00000000;

                                Text {
                                    text: @tr("刪除");
                                    color: #ff8ca8;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                TouchArea {
                                    enabled: !row.key-locked;
                                    clicked => {
                                        root.remove-row(key_idx);
                                    }
                                }
                            }
                        }
                    }
                }
            }

            HorizontalLayout {
                spacing: 8px;
                Rectangle {
                    horizontal-stretch: 1;
                    background: #00000000;
                }

                Rectangle {
                    min-width: 72px;
                    height: 28px;
                    horizontal-stretch: 0;
                    border-width: 1px;
                    border-color: AppTheme.prompt_chrome_border;
                    border-radius: 8px;
                    background: #00000000;

                    Text {
                        text: @tr("關閉");
                        color: AppTheme.text_muted;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: 12px;
                    }

                    TouchArea {
                        clicked => {
                            root.close();
                        }
                    }
                }

                Rectangle {
                    min-width: 72px;
                    height: 28px;
                    horizontal-stretch: 0;
                    border-width: 1px;
                    border-color: AppTheme.accent;
                    border-radius: 8px;
                    background: AppTheme.accent;

                    Text {
                        text: @tr("儲存");
                        color: AppTheme.text;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: 12px;
                        font-weight: 700;
                    }

                    TouchArea {
                        clicked => {
                            root.save();
                        }
                    }
                }
            }
        }
    }
}
