import { Button, LineEdit, ScrollView } from "std-widgets.slint";
import { AppTheme } from "theme.slint";
import { GjTerminalTabBar } from "components/gj_terminal_tab_bar.slint";

component GjDropZone inherits Rectangle {
    in-out property <string> file-path;
    in property <bool> has-image;
    in property <image> preview-image;
    callback load-requested(string);

    border-width: 1px;
    border-color: #3b3b4a;
    border-radius: AppTheme.radius;
    background: AppTheme.panel_alt;

    VerticalLayout {
        padding: AppTheme.gap_md;
        spacing: AppTheme.gap_sm;

        Text {
            text: "GjDropZone";
            color: AppTheme.text;
            font-weight: 700;
        }

        Text {
            text: "Paste a file path, then click Load";
            color: AppTheme.text_muted;
            font-size: 12px;
        }

        HorizontalLayout {
            spacing: AppTheme.gap_sm;

            path_input := LineEdit {
                text <=> root.file-path;
                placeholder-text: "D:/path/to/file_or_image";
                horizontal-stretch: 1;
            }

            Button {
                text: "Load";
                clicked => {
                    root.load-requested(path_input.text);
                }
            }
        }

        Text {
            text: root.file-path == "" ? "<no file>" : root.file-path;
            color: AppTheme.text_muted;
        }

        if root.has-image : Image {
            source: root.preview-image;
            width: 180px;
            height: 120px;
            image-fit: contain;
        }
    }
}

component GjViewer inherits Rectangle {
    in property <[string]> code-lines;
    in-out property <int> selected-line;
    in-out property <string> selected-context;

    border-width: 1px;
    border-color: #3b3b4a;
    border-radius: AppTheme.radius;
    background: AppTheme.panel_alt;

    VerticalLayout {
        padding: AppTheme.gap_sm;
        spacing: AppTheme.gap_sm;

        Text {
            text: "GjViewer (read-only)";
            color: AppTheme.text;
            font-weight: 700;
        }

        ScrollView {
            horizontal-stretch: 1;
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 1px;

                for line[index] in root.code-lines : Rectangle {
                    height: 24px;
                    background: root.selected-line == index + 1 ? #2a2230 : AppTheme.panel;

                    HorizontalLayout {
                        spacing: 0px;

                        Rectangle {
                            width: 64px;
                            background: #101018;

                            Text {
                                text: "\{index + 1}";
                                color: AppTheme.text_muted;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                                x: 0px;
                                width: parent.width - 8px;
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            background: #00000000;

                            Text {
                                text: line;
                                color: AppTheme.text;
                                vertical-alignment: center;
                                x: 10px;
                                width: parent.width - 12px;
                            }
                        }
                    }

                    TouchArea {
                        clicked => {
                            root.selected-line = index + 1;
                            root.selected-context = line;
                        }
                    }
                }
            }
        }
    }
}

component GjWorkspace inherits Rectangle {
    in-out property <string> file-path;
    in-out property <bool> has-image;
    in-out property <image> preview-image;
    in-out property <[string]> code-lines;
    in-out property <int> selected-line;
    in-out property <string> selected-context;
    in-out property <string> prompt;
    callback load-requested(string);

    background: AppTheme.bg;

    VerticalLayout {
        padding: AppTheme.gap_md;
        spacing: AppTheme.gap_md;

        GjDropZone {
            file-path <=> root.file-path;
            has-image: root.has-image;
            preview-image: root.preview-image;
            load-requested(path) => {
                root.load-requested(path);
            }
        }

        GjViewer {
            code-lines: root.code-lines;
            selected-line <=> root.selected-line;
            selected-context <=> root.selected-context;
            min-height: 280px;
        }

        Rectangle {
            border-width: 1px;
            border-color: #3b3b4a;
            border-radius: AppTheme.radius;
            background: AppTheme.panel_alt;
            min-height: 110px;

            VerticalLayout {
                padding: AppTheme.gap_sm;
                spacing: AppTheme.gap_sm;

                Text {
                    text: "Prompt";
                    color: AppTheme.text;
                    font-weight: 700;
                }

                LineEdit {
                    text <=> root.prompt;
                    placeholder-text: "補全框 Prompt...";
                }

                Text {
                    text: "Selected context: \{root.selected-context}";
                    color: AppTheme.text_muted;
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    title: "CliGJ - UI Foundation";
    width: 1200px;
    height: 760px;
    background: AppTheme.bg;

    in property <[string]> tab-titles;
    in property <int> tab-count: 0;
    in-out property <int> current-tab: 0;

    in-out property <string> ws-file-path: "";
    in-out property <bool> ws-has-image: false;
    in-out property <image> ws-preview-image;
    in-out property <[string]> ws-code-lines: [];
    in-out property <int> ws-selected-line: 0;
    in-out property <string> ws-selected-context: "";
    in-out property <string> ws-prompt: "";

    callback tab-changed(int);
    callback tab-close-requested(int);
    callback new-tab-requested;
    callback request-load-file(string);

    VerticalLayout {
        spacing: 0px;

        GjTerminalTabBar {
            tab-titles: root.tab-titles;
            tab-count: root.tab-count;
            current-tab: root.current-tab;
            select-tab(index) => {
                root.current-tab = index;
                root.tab-changed(index);
            }
            close-tab(index) => {
                root.tab-close-requested(index);
            }
            new-tab-requested => {
                root.new-tab-requested();
            }
        }

        Rectangle {
            vertical-stretch: 1;
            background: AppTheme.bg;

            VerticalLayout {
                padding: AppTheme.gap_md;
                spacing: AppTheme.gap_md;

                GjWorkspace {
                    file-path <=> root.ws-file-path;
                    has-image <=> root.ws-has-image;
                    preview-image <=> root.ws-preview-image;
                    code-lines <=> root.ws-code-lines;
                    selected-line <=> root.ws-selected-line;
                    selected-context <=> root.ws-selected-context;
                    prompt <=> root.ws-prompt;
                    load-requested(path) => {
                        root.request-load-file(path);
                    }
                }
            }
        }
    }
}
