import { AppTheme } from "theme.slint";
import { LogicalKey } from "key_labels.slint";
import { GjTerminalTabBar } from "components/gj_terminal_tab_bar.slint";
import { GjWorkspace } from "components/gj_workspace.slint";
import { TextEdit } from "std-widgets.slint";
import { PromptImageChip, TermLine } from "term_types.slint";

export component AppWindow inherits Window {
    title: "CliGJ - UI Foundation";
    preferred-width: 800px;
    preferred-height: 600px;
    background: AppTheme.bg;
    forward-focus: root_keys;

    in property <[string]> tab-titles;
    in property <int> tab-count: 0;
    in-out property <int> current-tab: 0;

    in-out property <string> ws-file-path: "";
    in-out property <[PromptImageChip]> ws-prompt-images: [];
    /// -1 = image zoom/lightbox closed; else index into `ws-prompt-images`.
    in-out property <int> ws-image-zoom-index: -1;
    in-out property <[string]> ws-code-lines: [];
    in-out property <string> ws-terminal-text: "";
    in-out property <[TermLine]> ws-terminal-lines: [];
    in-out property <int> ws-terminal-line-offset: 0;
    in-out property <int> ws-terminal-total-lines: 0;
    in-out property <bool> ws-auto-scroll: false;
    in-out property <bool> ws-terminal-select-mode: false;
    in-out property <bool> ws-rename-open: false;
    in-out property <int> ws-rename-index: -1;
    in-out property <string> ws-rename-text: "";
    in-out property <int> ws-selected-line: 0;
    in-out property <string> ws-selected-context: "";
    in-out property <string> ws-prompt: "";
    in-out property <[string]> ws-prompt-path-chips: [];
    in-out property <string> ws-cmd-type: "Command Prompt";
    in-out property <bool> ws-raw-input: false;

    /// `@` workspace file picker (composer only; hidden in Raw TTY).
    in-out property <bool> ws-at-picker-open: false;
    in-out property <[string]> ws-at-choices: [];
    in-out property <int> ws-at-selected: 0;
    in property <string> ws-workspace-root-label: "";
    in-out property <bool> ws-file-drop-visible: false;

    callback tab-changed(int);
    callback tab-close-requested(int);
    callback new-tab-requested;
    callback cmd-type-changed(string);
    callback submit-prompt;
    callback prompt-history-prev;
    callback prompt-history-next;
    /// bool: raw TTY mode; int: mod mask (see `key_encoding::mod_bits`); string: `event.text`; bool: shift.
    callback prompt-key-route(bool, int, string, bool) -> bool;
    callback toggle-raw-input-requested;
    callback inject-file-requested;
    callback inject-image-requested;
    callback prompt-image-remove-requested(int);
    callback prompt-images-clear-requested;
    callback rename-tab-requested(int);
    callback move-tab-requested(int, int);
    callback rename-commit(int, string);
    callback rename-cancel;
    callback at-picker-choose(int);
    callback prompt-chip-remove-requested(int);
    callback prompt-chip-clear-requested;
    callback terminal-selection-committed(int, int, int, int);
    callback terminal-viewport-changed;
    callback terminal-resize-requested(int, int);
    callback terminal-data-ready;
    callback prompt-image-zoom-requested(int);
    callback ai-model-selected(string);

    public function ws_scroll_terminal_to_bottom() {
        workspace.scroll_terminal_to_bottom();
    }

    public function ws_scroll_terminal_to_top() {
        workspace.scroll_terminal_to_top();
    }

    public function ws_apply_terminal_scroll_top_px(px: float) {
        workspace.apply-terminal-scroll-top-px(px);
    }

    public function ws_scroll_at_picker_into_view() {
        workspace.scroll_at_picker_into_view();
    }

    // Same mask as `GjPromptDropZone.pty_mod` / Rust `key_encoding::mod_bits`.
    function ws_pty_mod(event: KeyEvent) -> int {
        (event.modifiers.control ? 1 : 0)
        + (event.modifiers.shift ? 2 : 0)
        + (event.modifiers.alt ? 4 : 0)
        + (event.modifiers.meta ? 8 : 0)
    }

    /// Keys that must reach Rust (`route_prompt_key`) — not plain TextEdit insertion.
    /// Note: Enter is `"Return"` here (see `LogicalKey.tty_text`), not `"\n"`.
    function composer_needs_rust_key(t: string) -> bool {
        t == "Return" || t == "Tab" || t == "UpArrow" || t == "DownArrow"
    }

    // Global key capture: more reliable than TextEdit key handlers on Windows.
    root_keys := FocusScope {
        focus-on-click: true;
        focus-on-tab-navigation: true;
        capture-key-pressed(event) => {
            let t = LogicalKey.tty_text(event);
            let m = ws_pty_mod(event);
            // Fast path: normal typing stays in TextEdit, avoid Rust callback on every keystroke.
            if (!root.ws-raw-input && !root.ws-at-picker-open && m == 0
                    && t != "" && t != "\n" && !composer_needs_rust_key(t)) {
                return reject;
            }
            root.prompt-key-route(root.ws-raw-input, ws_pty_mod(event), LogicalKey.tty_text(event), event.modifiers.shift)
                ? accept
                : reject
        }

        VerticalLayout {
            spacing: 0px;

            GjTerminalTabBar {
                z: 20;
                tab-titles: root.tab-titles;
                tab-count: root.tab-count;
                current-tab: root.current-tab;
                current-cmd-type <=> root.ws-cmd-type;
                select-tab(index) => {
                    root.current-tab = index;
                    root.tab-changed(index);
                }
                close-tab(index) => {
                    root.tab-close-requested(index);
                }
                new-tab-requested => {
                    root.new-tab-requested();
                }
                cmd-type-selected(kind) => {
                    root.cmd-type-changed(kind);
                }
            rename-tab(index) => {
                root.rename-tab-requested(index);
            }
            move-tab(from, to) => {
                root.move-tab-requested(from, to);
            }
            }

            Rectangle {
                vertical-stretch: 1;
                background: AppTheme.bg;

                VerticalLayout {
                    padding: 0px;
                    spacing: 0px;

                    workspace := GjWorkspace {
                        file-path <=> root.ws-file-path;
                        prompt-images <=> root.ws-prompt-images;
                        code-lines <=> root.ws-code-lines;
                        terminal-text <=> root.ws-terminal-text;
                        terminal-lines <=> root.ws-terminal-lines;
                        terminal-line-offset <=> root.ws-terminal-line-offset;
                        terminal-total-lines <=> root.ws-terminal-total-lines;
                        auto-scroll <=> root.ws-auto-scroll;
                        terminal-select-mode <=> root.ws-terminal-select-mode;
                        selected-line <=> root.ws-selected-line;
                        selected-context <=> root.ws-selected-context;
                        prompt <=> root.ws-prompt;
                        prompt-path-chips <=> root.ws-prompt-path-chips;
                        raw-input-enabled <=> root.ws-raw-input;
                        at-picker-open <=> root.ws-at-picker-open;
                        at-choices <=> root.ws-at-choices;
                        at-selected <=> root.ws-at-selected;
                        workspace-root-label: root.ws-workspace-root-label;
                        submit-requested => {
                            root.submit-prompt();
                        }
                        history-prev-requested => {
                            root.prompt-history-prev();
                        }
                        history-next-requested => {
                            root.prompt-history-next();
                        }
                        prompt-key-route(raw, mods, key, shift) => {
                            root.prompt-key-route(raw, mods, key, shift);
                        }
                        raw-input-toggle-requested => {
                            root.toggle-raw-input-requested();
                        }
                        inject-file-requested => {
                            root.inject-file-requested();
                        }
                        inject-image-requested => {
                            root.inject-image-requested();
                        }
                        prompt-image-remove-requested(idx) => {
                            root.prompt-image-remove-requested(idx);
                        }
                        prompt-images-clear-requested => {
                            root.prompt-images-clear-requested();
                        }
                        prompt-image-zoom-requested(idx) => {
                            root.ws-image-zoom-index = idx;
                        }
                        at-picker-choose(index) => {
                            root.at-picker-choose(index);
                        }
                        prompt-chip-remove-requested(index) => {
                            root.prompt-chip-remove-requested(index);
                        }
                        prompt-chip-clear-requested => {
                            root.prompt-chip-clear-requested();
                        }
                        terminal-selection-committed(sr, sc, er, ec) => {
                            root.terminal-selection-committed(sr, sc, er, ec);
                        }
                        terminal-viewport-changed => {
                            root.terminal-viewport-changed();
                        }
                        ai-model-selected(val) => {
                            root.ai-model-selected(val);
                        }
                        terminal-resize-requested(cols, rows) => {
                            root.terminal-resize-requested(cols, rows);
                        }
                    }
                }
            }
        }
    }

    public function ws_bump_terminal_size() {
        workspace.bump-terminal-size();
    }

    if root.ws-rename-open : Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #00000080;
        z: 100;

        Rectangle {
            width: 360px;
            height: 140px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: AppTheme.panel;
            border-width: 1px;
            border-color: AppTheme.prompt_chrome_border;
            border-radius: 10px;

            VerticalLayout {
                padding: 12px;
                spacing: 10px;

                Text {
                    text: @tr("重新命名標籤");
                    color: AppTheme.text;
                    font-size: 13px;
                    font-weight: 600;
                }

                TextEdit {
                    text <=> root.ws-rename-text;
                    font-size: 13px;
                    wrap: no-wrap;
                    key-pressed(event) => {
                        if (event.text == Key.Return) {
                            root.rename-commit(root.ws-rename-index, root.ws-rename-text);
                            accept
                        } else if (event.text == Key.Escape) {
                            root.rename-cancel();
                            accept
                        } else {
                            reject
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    Rectangle { horizontal-stretch: 1; background: #00000000; }

                    Rectangle {
                        min-width: 72px;
                        height: 28px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 8px;
                        background: #00000000;
                        Text {
                            text: @tr("取消");
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 12px;
                        }
                        TouchArea {
                            clicked => { root.rename-cancel(); }
                        }
                    }

                    Rectangle {
                        min-width: 72px;
                        height: 28px;
                        border-width: 1px;
                        border-color: AppTheme.accent;
                        border-radius: 8px;
                        background: AppTheme.accent;
                        Text {
                            text: @tr("確定");
                            color: AppTheme.text;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 12px;
                            font-weight: 700;
                        }
                        TouchArea {
                            clicked => { root.rename-commit(root.ws-rename-index, root.ws-rename-text); }
                        }
                    }
                }
            }
        }
    }

    out property <float> ws-terminal-scroll-top-px: workspace.terminal-scroll-top-px;
    out property <float> ws-terminal-viewport-height-px: workspace.terminal-viewport-height-px;

    if root.ws-image-zoom-index >= 0
            && root.ws-image-zoom-index < root.ws-prompt-images.length: Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #0a0a0fe8;
        z: 450;

        TouchArea {
            width: 100%;
            height: 100%;
            clicked => {
                root.ws-image-zoom-index = -1;
            }

            VerticalLayout {
                alignment: center;
                padding: 24px;
                spacing: 10px;

                Rectangle {
                    width: min(parent.width - 48px, 900px);
                    height: min(parent.height - 80px, 720px);
                    border-width: 1px;
                    border-color: AppTheme.prompt_chrome_border;
                    border-radius: 12px;
                    background: #14161c;
                    clip: true;

                    Image {
                        source: root.ws-prompt-images[root.ws-image-zoom-index].thumb;
                        width: 100%;
                        height: 100%;
                        image-fit: contain;
                    }
                }

                Text {
                    text: @tr("點擊任意處關閉");
                    color: AppTheme.text_muted;
                    font-size: 12px;
                    horizontal-alignment: center;
                }
            }
        }
    }

    if root.ws-file-drop-visible : Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #1a1b26c0; // 半透明背景
        z: 500;

        Rectangle {
            width: 240px;
            height: 120px;
            border-width: 2px;
            border-color: AppTheme.accent;
            border-radius: 12px;
            background: AppTheme.bg;

            VerticalLayout {
                alignment: center;
                spacing: 12px;
                Text {
                    // ASCII "+" — U+2295 (⊕) is often missing from bundled UI fonts and renders as tofu.
                    text: "+";
                    font-size: 32px;
                    font-weight: 300;
                    color: AppTheme.accent;
                    horizontal-alignment: center;
                }
                Text {
                    text: @tr("放開以加入檔案");
                    font-size: 16px;
                    font-weight: 600;
                    color: AppTheme.text;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
