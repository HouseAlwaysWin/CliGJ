import { AppTheme } from "theme.slint";
import { LogicalKey } from "key_labels.slint";
import { GjTerminalTabBar } from "components/gj_terminal_tab_bar.slint";
import { GjWorkspace } from "components/gj_workspace.slint";
import { ComboBox, LineEdit, ScrollView, TextEdit } from "std-widgets.slint";
import { InteractiveCmdEditorRow, PromptImageChip, TermLine } from "term_types.slint";

export component AppWindow inherits Window {
    title: "CliGJ";
    icon: @image-url("../src/asset/logo3.png");
    no-frame: true;
    resize-border-width: AppTheme.chrome_resize_border;
    preferred-width: 800px;
    preferred-height: 600px;
    min-width: 520px;
    // Keep enough terminal rows for interactive TUIs like Gemini CLI. At smaller heights the
    // application itself switches layout/reflows aggressively, which cannot be made stable purely
    // from our side after a PTY resize.
    min-height: 600px;
    background: AppTheme.bg;
    forward-focus: root_keys;

    in property <[string]> tab-titles;
    in property <int> tab-count: 0;
    in-out property <int> current-tab: 0;

    in-out property <string> ws-file-path: "";
    in-out property <[PromptImageChip]> ws-prompt-images: [];
    /// -1 = image zoom/lightbox closed; else index into `ws-prompt-images`.
    in-out property <int> ws-image-zoom-index: -1;
    in-out property <[string]> ws-code-lines: [];
    in-out property <string> ws-terminal-text: "";
    in-out property <[TermLine]> ws-terminal-lines: [];
    in-out property <int> ws-terminal-line-offset: 0;
    in-out property <int> ws-terminal-total-lines: 0;
    in-out property <bool> ws-auto-scroll: false;
    in-out property <bool> ws-terminal-select-mode: false;
    in-out property <bool> ws-rename-open: false;
    in-out property <int> ws-rename-index: -1;
    in-out property <string> ws-rename-text: "";
    in-out property <int> ws-selected-line: 0;
    in-out property <string> ws-selected-context: "";
    in-out property <string> ws-prompt: "";
    in-out property <[string]> ws-prompt-path-chips: [];
    in-out property <string> ws-cmd-type: "Command Prompt";
    in-out property <[string]> ws-cmd-type-choices: ["Command Prompt", "PowerShell"];
    in-out property <bool> ws-raw-input: false;
    in-out property <bool> ws-ipc-running: false;
    in-out property <int> ws-ipc-client-count: 0;
    in-out property <string> ws-ipc-status-text: "IPC OFF";
    in-out property <[string]> ws-interactive-command-choices: [];
    in-out property <bool> ws-interactive-manage-open: false;
    in-out property <[InteractiveCmdEditorRow]> ws-interactive-manage-rows: [];
    in-out property <bool> ws-shell-manage-open: false;
    in-out property <[InteractiveCmdEditorRow]> ws-shell-manage-rows: [];
    in-out property <bool> ws-shell-manage-saved-hint: false;
    in-out property <string> ws-shell-settings-nav: "啟動";
    in-out property <string> ws-shell-startup-language: "預設";
    in-out property <string> ws-shell-startup-default-profile: "Command Prompt";
    in-out property <[string]> ws-shell-startup-language-choices: ["預設", "中文", "English"];

    /// `@` workspace file picker (composer only; hidden in Raw TTY).
    in-out property <bool> ws-at-picker-open: false;
    in-out property <[string]> ws-at-choices: [];
    in-out property <int> ws-at-selected: 0;
    in property <string> ws-workspace-root-label: "";
    in-out property <bool> ws-file-drop-visible: false;
    /// 無框視窗：與 OS 同步，用於最大化按鈕圖示（□ / 還原）。
    in-out property <bool> ws-window-maximized: false;

    callback tab-changed(int);
    callback tab-close-requested(int);
    callback new-tab-requested;
    callback cmd-type-changed(string);
    callback submit-prompt;
    callback prompt-history-prev;
    callback prompt-history-next;
    /// bool: raw TTY mode; int: mod mask (see `key_encoding::mod_bits`); string: `event.text`; bool: shift.
    callback prompt-key-route(bool, int, string, bool) -> bool;
    callback toggle-raw-input-requested;
    callback toggle-ipc-server-requested;
    callback inject-file-requested;
    callback inject-image-requested;
    callback prompt-image-remove-requested(int);
    callback prompt-images-clear-requested;
    callback rename-tab-requested(int);
    callback move-tab-requested(int, int);
    callback rename-commit(int, string);
    callback rename-cancel;
    callback at-picker-choose(int);
    callback prompt-chip-remove-requested(int);
    callback prompt-chip-clear-requested;
    callback terminal-selection-committed(int, int, int, int);
    callback terminal-viewport-changed;
    callback terminal-resize-requested(int, int);
    callback terminal-wheel(int) -> bool;
    callback terminal-data-ready;
    callback prompt-image-zoom-requested(int);
    callback interactive-command-selected(string);
    callback manage-cmd-types-requested;
    callback manage-interactive-commands-requested;
    callback manage-add-interactive-row;
    callback remove-interactive-manage-row(int);
    callback interactive-manage-name-edited(int, string);
    callback interactive-manage-line-edited(int, string);
    callback save-interactive-manage;
    callback close-interactive-manage;
    callback manage-add-shell-row;
    callback remove-shell-manage-row(int);
    callback shell-manage-name-edited(int, string);
    callback shell-manage-line-edited(int, string);
    callback shell-manage-workspace-edited(int, string);
    callback shell-manage-workspace-pick-folder(int);
    callback save-shell-manage;
    callback save-shell-startup-settings;
    callback close-shell-manage;
    callback toggle-shell-manage-row-expanded(int);
    callback window-chrome-drag();
    callback window-chrome-minimize();
    callback window-chrome-maximize();
    callback window-chrome-close();

    public function ws_scroll_terminal_to_bottom() {
        workspace.scroll_terminal_to_bottom();
    }

    public function ws_scroll_terminal_to_top() {
        workspace.scroll_terminal_to_top();
    }

    public function ws_apply_terminal_scroll_top_px(px: float) {
        workspace.apply-terminal-scroll-top-px(px);
    }

    public function ws_scroll_at_picker_into_view() {
        workspace.scroll_at_picker_into_view();
    }

    // Same mask as `GjPromptDropZone.pty_mod` / Rust `key_encoding::mod_bits`.
    function ws_pty_mod(event: KeyEvent) -> int {
        (event.modifiers.control ? 1 : 0)
        + (event.modifiers.shift ? 2 : 0)
        + (event.modifiers.alt ? 4 : 0)
        + (event.modifiers.meta ? 8 : 0)
    }

    /// Keys that must reach Rust (`route_prompt_key`) — not plain TextEdit insertion.
    /// Note: Enter is `"Return"` here (see `LogicalKey.tty_text`), not `"\n"`.
    function composer_needs_rust_key(t: string) -> bool {
        t == "Return" || t == "Tab" || t == "UpArrow" || t == "DownArrow"
    }

    // Global key capture: more reliable than TextEdit key handlers on Windows.
    root_keys := FocusScope {
        focus-on-click: true;
        focus-on-tab-navigation: true;
        capture-key-pressed(event) => {
            let t = LogicalKey.tty_text(event);
            let m = ws_pty_mod(event);
            if (root.ws-interactive-manage-open || root.ws-shell-manage-open) {
                return reject;
            }
            // Fast path: normal typing stays in TextEdit, avoid Rust callback on every keystroke.
            if (!root.ws-raw-input && !root.ws-at-picker-open && !root.ws-interactive-manage-open && !root.ws-shell-manage-open && m == 0
                    && t != "" && t != "\n" && !composer_needs_rust_key(t)) {
                return reject;
            }
            root.prompt-key-route(root.ws-raw-input, ws_pty_mod(event), LogicalKey.tty_text(event), event.modifiers.shift)
                ? accept
                : reject
        }

        VerticalLayout {
            spacing: 0px;

            Rectangle {
                height: 34px;
                background: AppTheme.tab_bar_bg;
                border-width: 0px;

                // Title strip: [ icon | empty pad same width as controls ] [ centered title ] [ min / max / close ]
                // Left and right rails are both 138px (3×46px) so "CliGJ" sits on the visual center line.
                HorizontalLayout {
                    spacing: 0px;
                    alignment: stretch;

                    Rectangle {
                        width: 138px;
                        height: 34px;
                        background: #00000000;

                        Image {
                            x: 10px;
                            y: (parent.height - self.height) / 2;
                            width: 22px;
                            height: 22px;
                            source: @image-url("../src/asset/logo3.png");
                        }

                        left-chrome-drag := TouchArea {
                            y: AppTheme.chrome_resize_border;
                            width: 100%;
                            height: parent.height - AppTheme.chrome_resize_border;
                            pointer-event(e) => {
                                if (e.kind == PointerEventKind.down && e.button == PointerEventButton.left) {
                                    root.window-chrome-drag();
                                }
                            }
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        min-height: 34px;
                        background: #00000000;

                        Text {
                            width: 100%;
                            height: 100%;
                            text: "CliGJ";
                            color: AppTheme.text;
                            font-size: 14px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        center-chrome-drag := TouchArea {
                            y: AppTheme.chrome_resize_border;
                            width: 100%;
                            height: parent.height - AppTheme.chrome_resize_border;
                            pointer-event(e) => {
                                if (e.kind == PointerEventKind.down && e.button == PointerEventButton.left) {
                                    root.window-chrome-drag();
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 0px;

                        Rectangle {
                            width: 46px;
                            height: 34px;
                            background: min_ta.has-hover ? #3c3c3c : #00000000;

                            Text {
                                width: 100%;
                                height: 100%;
                                text: "\u{e921}";
                                color: AppTheme.text_muted;
                                font-size: 11px;
                                font-family: AppTheme.chrome_caption_icon_font;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            min_ta := TouchArea {
                                width: 100%;
                                height: 100%;
                                clicked => {
                                    root.window-chrome-minimize();
                                }
                            }
                        }

                        Rectangle {
                            width: 46px;
                            height: 34px;
                            background: max_ta.has-hover ? #3c3c3c : #00000000;

                            Text {
                                width: 100%;
                                height: 100%;
                                text: root.ws-window-maximized ? "\u{e923}" : "\u{e922}";
                                color: AppTheme.text_muted;
                                font-size: 11px;
                                font-family: AppTheme.chrome_caption_icon_font;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            max_ta := TouchArea {
                                width: 100%;
                                height: 100%;
                                clicked => {
                                    root.window-chrome-maximize();
                                }
                            }
                        }

                        Rectangle {
                            width: 46px;
                            height: 34px;
                            background: close_ta.has-hover ? #e81123 : #00000000;

                            Text {
                                width: 100%;
                                height: 100%;
                                text: "\u{e8bb}";
                                color: close_ta.has-hover ? #ffffff : AppTheme.text_muted;
                                font-size: 11px;
                                font-family: AppTheme.chrome_caption_icon_font;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            close_ta := TouchArea {
                                width: 100%;
                                height: 100%;
                                clicked => {
                                    root.window-chrome-close();
                                }
                            }
                        }
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: AppTheme.tab_separator;
            }

            GjTerminalTabBar {
                z: 20;
                tab-titles: root.tab-titles;
                tab-count: root.tab-count;
                current-tab: root.current-tab;
                current-cmd-type <=> root.ws-cmd-type;
                cmd-type-choices: root.ws-cmd-type-choices;
                select-tab(index) => {
                    root.current-tab = index;
                    root.tab-changed(index);
                }
                close-tab(index) => {
                    root.tab-close-requested(index);
                }
                new-tab-requested => {
                    root.new-tab-requested();
                }
                cmd-type-selected(kind) => {
                    root.cmd-type-changed(kind);
                }
                manage-cmd-types-requested => {
                    root.manage-cmd-types-requested();
                }
            rename-tab(index) => {
                root.rename-tab-requested(index);
            }
            move-tab(from, to) => {
                root.move-tab-requested(from, to);
            }
            }

            Rectangle {
                vertical-stretch: 1;
                background: AppTheme.bg;

                VerticalLayout {
                    padding: 0px;
                    spacing: 0px;

                    workspace := GjWorkspace {
                        file-path <=> root.ws-file-path;
                        prompt-images <=> root.ws-prompt-images;
                        code-lines <=> root.ws-code-lines;
                        terminal-text <=> root.ws-terminal-text;
                        terminal-lines <=> root.ws-terminal-lines;
                        terminal-line-offset <=> root.ws-terminal-line-offset;
                        terminal-total-lines <=> root.ws-terminal-total-lines;
                        auto-scroll <=> root.ws-auto-scroll;
                        terminal-select-mode <=> root.ws-terminal-select-mode;
                        selected-line <=> root.ws-selected-line;
                        selected-context <=> root.ws-selected-context;
                        prompt <=> root.ws-prompt;
                        prompt-path-chips <=> root.ws-prompt-path-chips;
                        raw-input-enabled <=> root.ws-raw-input;
                        ipc-running: root.ws-ipc-running;
                        ipc-client-count: root.ws-ipc-client-count;
                        ipc-status-text: root.ws-ipc-status-text;
                        interactive-command-choices: root.ws-interactive-command-choices;
                        at-picker-open <=> root.ws-at-picker-open;
                        at-choices <=> root.ws-at-choices;
                        at-selected <=> root.ws-at-selected;
                        workspace-root-label: root.ws-workspace-root-label;
                        submit-requested => {
                            root.submit-prompt();
                        }
                        history-prev-requested => {
                            root.prompt-history-prev();
                        }
                        history-next-requested => {
                            root.prompt-history-next();
                        }
                        prompt-key-route(raw, mods, key, shift) => {
                            root.prompt-key-route(raw, mods, key, shift);
                        }
                        raw-input-toggle-requested => {
                            root.toggle-raw-input-requested();
                        }
                        ipc-toggle-requested => {
                            root.toggle-ipc-server-requested();
                        }
                        inject-file-requested => {
                            root.inject-file-requested();
                        }
                        inject-image-requested => {
                            root.inject-image-requested();
                        }
                        prompt-image-remove-requested(idx) => {
                            root.prompt-image-remove-requested(idx);
                        }
                        prompt-images-clear-requested => {
                            root.prompt-images-clear-requested();
                        }
                        prompt-image-zoom-requested(idx) => {
                            root.ws-image-zoom-index = idx;
                        }
                        at-picker-choose(index) => {
                            root.at-picker-choose(index);
                        }
                        prompt-chip-remove-requested(index) => {
                            root.prompt-chip-remove-requested(index);
                        }
                        prompt-chip-clear-requested => {
                            root.prompt-chip-clear-requested();
                        }
                        terminal-selection-committed(sr, sc, er, ec) => {
                            root.terminal-selection-committed(sr, sc, er, ec);
                        }
                        terminal-viewport-changed => {
                            root.terminal-viewport-changed();
                        }
                        interactive-command-selected(val) => {
                            root.interactive-command-selected(val);
                        }
                        manage-interactive-commands-requested => {
                            root.manage-interactive-commands-requested();
                        }
                        terminal-resize-requested(cols, rows) => {
                            root.terminal-resize-requested(cols, rows);
                        }
                        terminal-wheel(delta) => {
                            root.terminal-wheel(delta)
                        }
                    }
                }
            }
        }
    }

    public function ws_bump_terminal_size() {
        workspace.bump-terminal-size();
    }

    if root.ws-rename-open : Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #00000080;
        z: 100;

        Rectangle {
            width: 360px;
            height: 140px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: AppTheme.panel;
            border-width: 1px;
            border-color: AppTheme.prompt_chrome_border;
            border-radius: 10px;

            VerticalLayout {
                padding: 12px;
                spacing: 10px;

                Text {
                    text: @tr("重新命名標籤");
                    color: AppTheme.text;
                    font-size: 13px;
                    font-weight: 600;
                }

                TextEdit {
                    text <=> root.ws-rename-text;
                    font-size: 13px;
                    wrap: no-wrap;
                    key-pressed(event) => {
                        if (event.text == Key.Return) {
                            root.rename-commit(root.ws-rename-index, root.ws-rename-text);
                            accept
                        } else if (event.text == Key.Escape) {
                            root.rename-cancel();
                            accept
                        } else {
                            reject
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    Rectangle { horizontal-stretch: 1; background: #00000000; }

                    Rectangle {
                        min-width: 72px;
                        height: 28px;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 8px;
                        background: #00000000;
                        Text {
                            text: @tr("取消");
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 12px;
                        }
                        TouchArea {
                            clicked => { root.rename-cancel(); }
                        }
                    }

                    Rectangle {
                        min-width: 72px;
                        height: 28px;
                        border-width: 1px;
                        border-color: AppTheme.accent;
                        border-radius: 8px;
                        background: AppTheme.accent;
                        Text {
                            text: @tr("確定");
                            color: AppTheme.text;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 12px;
                            font-weight: 700;
                        }
                        TouchArea {
                            clicked => { root.rename-commit(root.ws-rename-index, root.ws-rename-text); }
                        }
                    }
                }
            }
        }
    }

    if root.ws-interactive-manage-open : Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #00000080;
        z: 106;

        Rectangle {
            width: 560px;
            height: 420px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: AppTheme.panel;
            border-width: 1px;
            border-color: AppTheme.prompt_chrome_border;
            border-radius: 10px;

            VerticalLayout {
                padding: 12px;
                spacing: 8px;

                Text {
                    text: @tr("指令設定");
                    color: AppTheme.text;
                    font-size: 13px;
                    font-weight: 600;
                }

                Text {
                    text: @tr("內建 Gemini / Codex / Claude / Copilot 無法刪除；變更後請按儲存。");
                    color: AppTheme.text_muted;
                    font-size: 11px;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;

                    Rectangle {
                        min-width: 64px;
                        height: 26px;
                        horizontal-stretch: 0;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 8px;
                        background: #00000000;

                        Text {
                            text: @tr("新增");
                            color: AppTheme.text;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 12px;
                            font-weight: 600;
                        }

                        TouchArea {
                            clicked => {
                                root.manage-add-interactive-row();
                            }
                        }
                    }
                }

                ScrollView {
                    vertical-stretch: 1;
                    min-height: 0px;

                    VerticalLayout {
                        alignment: start;
                        spacing: 6px;

                        for row[key_idx] in root.ws-interactive-manage-rows: Rectangle {
                            min-height: 32px;
                            border-width: 1px;
                            border-color: AppTheme.prompt_chrome_border;
                            border-radius: 6px;
                            background: #00000000;

                            HorizontalLayout {
                                padding-left: 6px;
                                padding-right: 6px;
                                spacing: 6px;
                                alignment: center;

                                if row.key-locked: Rectangle {
                                    horizontal-stretch: 1;
                                    min-width: 96px;
                                    min-height: 26px;
                                    background: #00000020;
                                    border-radius: 4px;

                                    Text {
                                        text: row.name;
                                        color: AppTheme.text_muted;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        horizontal-alignment: left;
                                        overflow: elide;
                                    }
                                }

                                if !row.key-locked: LineEdit {
                                    horizontal-stretch: 1;
                                    min-width: 96px;
                                    font-size: 12px;
                                    text: row.name;
                                    edited(new_text) => {
                                        root.interactive-manage-name-edited(key_idx, new_text);
                                    }
                                }

                                Text {
                                    text: ">";
                                    color: AppTheme.text_muted;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 0;
                                }

                                LineEdit {
                                    horizontal-stretch: 2;
                                    min-width: 140px;
                                    font-size: 12px;
                                    text: row.line;
                                    edited(new_text) => {
                                        root.interactive-manage-line-edited(key_idx, new_text);
                                    }
                                }

                                Rectangle {
                                    min-width: 44px;
                                    max-width: 52px;
                                    height: 24px;
                                    horizontal-stretch: 0;
                                    border-width: 1px;
                                    border-color: #ff4f6d;
                                    border-radius: 6px;
                                    background: #00000000;

                                    Text {
                                        text: @tr("刪除");
                                        color: #ff8ca8;
                                        font-size: 11px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }

                                    TouchArea {
                                        enabled: !row.key-locked;
                                        clicked => {
                                            root.remove-interactive-manage-row(key_idx);
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        horizontal-stretch: 1;
                        background: #00000000;
                    }

                    Rectangle {
                        min-width: 72px;
                        height: 28px;
                        horizontal-stretch: 0;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 8px;
                        background: #00000000;

                        Text {
                            text: @tr("關閉");
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 12px;
                        }

                        TouchArea {
                            clicked => {
                                root.close-interactive-manage();
                            }
                        }
                    }

                    Rectangle {
                        min-width: 72px;
                        height: 28px;
                        horizontal-stretch: 0;
                        border-width: 1px;
                        border-color: AppTheme.accent;
                        border-radius: 8px;
                        background: AppTheme.accent;

                        Text {
                            text: @tr("儲存");
                            color: AppTheme.text;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 12px;
                            font-weight: 700;
                        }

                        TouchArea {
                            clicked => {
                                root.save-interactive-manage();
                            }
                        }
                    }
                }
            }
        }
    }

    if root.ws-shell-manage-open : Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: AppTheme.bg;
        z: 107;
        HorizontalLayout {
            spacing: 0px;

            Rectangle {
                width: 196px;
                vertical-stretch: 1;
                background: AppTheme.panel;
                border-width: 0px;

                VerticalLayout {
                    padding: 10px;
                    spacing: 8px;

                    Rectangle {
                        min-width: 64px;
                        height: 28px;
                        horizontal-stretch: 0;
                        border-width: 1px;
                        border-color: AppTheme.prompt_chrome_border;
                        border-radius: 8px;
                        background: #00000000;

                        Text {
                            text: @tr("返回");
                            color: AppTheme.text_muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            font-size: 12px;
                        }

                        TouchArea {
                            clicked => {
                                root.close-shell-manage();
                            }
                        }
                    }

                    Rectangle {
                        height: 1px;
                        background: AppTheme.prompt_chrome_border;
                    }

                    for nav in [
                        @tr("啟動"),
                        @tr("互動"),
                        @tr("外觀"),
                        @tr("命令提示設定")
                    ]: Rectangle {
                        height: 30px;
                        border-radius: 6px;
                        background: nav == root.ws-shell-settings-nav ? #2d2d30 : #00000000;

                        Text {
                            text: nav;
                            color: nav == root.ws-shell-settings-nav ? AppTheme.text : AppTheme.text_muted;
                            vertical-alignment: center;
                            horizontal-alignment: left;
                            x: 10px;
                            width: parent.width - 12px;
                            font-size: 12px;
                            overflow: elide;
                        }

                        TouchArea {
                            clicked => {
                                root.ws-shell-settings-nav = nav;
                                root.ws-shell-manage-saved-hint = false;
                            }
                        }
                    }

                    Rectangle {
                        vertical-stretch: 1;
                        background: #00000000;
                    }
                }
            }

            Rectangle {
                width: 1px;
                vertical-stretch: 1;
                background: AppTheme.prompt_chrome_border;
            }

            Rectangle {
                vertical-stretch: 1;
                horizontal-stretch: 1;
                background: AppTheme.bg;

                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;

                    Text {
                        text: root.ws-shell-settings-nav == @tr("啟動")
                            ? @tr("設定 / 啟動")
                            : @tr("設定 / 命令提示設定");
                        color: AppTheme.text;
                        font-size: 13px;
                        font-weight: 600;
                    }

                    if root.ws-shell-settings-nav == @tr("啟動"): VerticalLayout {
                        spacing: 10px;
                        vertical-stretch: 1;

                        Text {
                            text: @tr("設定新分頁預設啟動行為。");
                            color: AppTheme.text_muted;
                            font-size: 11px;
                            wrap: word-wrap;
                        }

                        Rectangle {
                            height: 42px;
                            border-width: 1px;
                            border-color: AppTheme.prompt_chrome_border;
                            border-radius: 6px;
                            background: #00000000;

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 10px;
                                alignment: center;

                                Text {
                                    text: @tr("預設設定檔");
                                    color: AppTheme.text_muted;
                                    font-size: 12px;
                                    min-width: 120px;
                                    horizontal-stretch: 0;
                                }

                                Rectangle {
                                    horizontal-stretch: 1;
                                    background: #00000000;
                                }

                                Rectangle {
                                    width: 240px;
                                    horizontal-stretch: 0;
                                    background: #00000000;

                                    ComboBox {
                                        width: 100%;
                                        model: root.ws-cmd-type-choices;
                                        current-value <=> root.ws-shell-startup-default-profile;
                                        selected(val) => {
                                            root.ws-shell-startup-default-profile = val;
                                            self.current-value = val;
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle {
                            height: 42px;
                            border-width: 1px;
                            border-color: AppTheme.prompt_chrome_border;
                            border-radius: 6px;
                            background: #00000000;

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 10px;
                                alignment: center;

                                Text {
                                    text: @tr("語言");
                                    color: AppTheme.text_muted;
                                    font-size: 12px;
                                    min-width: 120px;
                                    horizontal-stretch: 0;
                                }

                                Rectangle {
                                    horizontal-stretch: 1;
                                    background: #00000000;
                                }

                                Rectangle {
                                    width: 240px;
                                    horizontal-stretch: 0;
                                    background: #00000000;

                                    ComboBox {
                                        width: 100%;
                                        model: root.ws-shell-startup-language-choices;
                                        current-value <=> root.ws-shell-startup-language;
                                        selected(val) => {
                                            root.ws-shell-startup-language = val;
                                            self.current-value = val;
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                            background: #00000000;
                        }
                    }

                    if root.ws-shell-settings-nav == @tr("命令提示設定"): VerticalLayout {
                        spacing: 8px;
                        vertical-stretch: 1;

                        Text {
                            text: @tr("預設 Command Prompt / PowerShell 無法刪除；可新增自訂啟動命令。");
                            color: AppTheme.text_muted;
                            font-size: 11px;
                            horizontal-alignment: left;
                            wrap: word-wrap;
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: end;

                            Rectangle {
                                min-width: 64px;
                                height: 26px;
                                horizontal-stretch: 0;
                                border-width: 1px;
                                border-color: AppTheme.prompt_chrome_border;
                                border-radius: 8px;
                                background: #00000000;

                                Text {
                                    text: @tr("新增");
                                    color: AppTheme.text;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    font-size: 12px;
                                    font-weight: 600;
                                }

                                TouchArea {
                                    clicked => {
                                        root.manage-add-shell-row();
                                    }
                                }
                            }
                        }

                        ScrollView {
                            vertical-stretch: 1;
                            min-height: 0px;

                            VerticalLayout {
                                alignment: start;
                                spacing: 6px;

                                for row[key_idx] in root.ws-shell-manage-rows: Rectangle {
                                    border-width: 1px;
                                    border-color: AppTheme.prompt_chrome_border;
                                    border-radius: 6px;
                                    background: #00000000;

                                    VerticalLayout {
                                        padding: 0px;
                                        spacing: 0px;

                                        Rectangle {
                                            min-height: 34px;
                                            background: #00000000;

                                            HorizontalLayout {
                                                padding-left: 8px;
                                                padding-right: 8px;
                                                spacing: 8px;
                                                alignment: start;

                                                Text {
                                                    text: row.expanded ? "v" : ">";
                                                    color: AppTheme.text_muted;
                                                    font-size: 12px;
                                                    vertical-alignment: center;
                                                    horizontal-stretch: 0;
                                                    width: 14px;
                                                    horizontal-alignment: left;
                                                }

                                                Text {
                                                    text: row.name;
                                                    color: row.key-locked ? AppTheme.text_muted : AppTheme.text;
                                                    font-size: 12px;
                                                    font-weight: 600;
                                                    vertical-alignment: center;
                                                    horizontal-stretch: 1;
                                                    horizontal-alignment: left;
                                                    overflow: elide;
                                                }
                                            }

                                            TouchArea {
                                                clicked => {
                                                    root.toggle-shell-manage-row-expanded(key_idx);
                                                }
                                            }
                                        }

                                        if row.expanded: VerticalLayout {
                                            padding-left: 8px;
                                            padding-right: 8px;
                                            padding-bottom: 8px;
                                            spacing: 8px;

                                            HorizontalLayout {
                                                spacing: 6px;
                                                alignment: start;

                                                if row.key-locked: Rectangle {
                                                    horizontal-stretch: 1;
                                                    min-width: 96px;
                                                    min-height: 26px;
                                                    background: #00000020;
                                                    border-radius: 4px;

                                                    Text {
                                                        text: row.name;
                                                        color: AppTheme.text_muted;
                                                        font-size: 12px;
                                                        vertical-alignment: center;
                                                        horizontal-alignment: left;
                                                        overflow: elide;
                                                    }
                                                }

                                                if !row.key-locked: LineEdit {
                                                    horizontal-stretch: 1;
                                                    min-width: 96px;
                                                    font-size: 12px;
                                                    text: row.name;
                                                    edited(new_text) => {
                                                        root.shell-manage-name-edited(key_idx, new_text);
                                                    }
                                                }

                                                Text {
                                                    text: ">";
                                                    color: AppTheme.text_muted;
                                                    font-size: 12px;
                                                    vertical-alignment: center;
                                                    horizontal-stretch: 0;
                                                }

                                                LineEdit {
                                                    horizontal-stretch: 2;
                                                    min-width: 180px;
                                                    font-size: 12px;
                                                    text: row.line;
                                                    edited(new_text) => {
                                                        root.shell-manage-line-edited(key_idx, new_text);
                                                    }
                                                }

                                                Rectangle {
                                                    min-width: 44px;
                                                    max-width: 52px;
                                                    height: 24px;
                                                    horizontal-stretch: 0;
                                                    border-width: 1px;
                                                    border-color: #ff4f6d;
                                                    border-radius: 6px;
                                                    background: #00000000;

                                                    Text {
                                                        text: @tr("刪除");
                                                        color: #ff8ca8;
                                                        font-size: 11px;
                                                        horizontal-alignment: center;
                                                        vertical-alignment: center;
                                                    }

                                                    TouchArea {
                                                        enabled: !row.key-locked;
                                                        clicked => {
                                                            root.remove-shell-manage-row(key_idx);
                                                        }
                                                    }
                                                }
                                            }

                                            VerticalLayout {
                                                spacing: 4px;

                                                Text {
                                                    text: @tr("工作區設定");
                                                    color: AppTheme.text_muted;
                                                    font-size: 11px;
                                                    horizontal-alignment: left;
                                                    wrap: word-wrap;
                                                }

                                                HorizontalLayout {
                                                    spacing: 8px;
                                                    alignment: start;

                                                    LineEdit {
                                                        horizontal-stretch: 1;
                                                        min-height: 28px;
                                                        font-size: 12px;
                                                        text: row.workspace-path;
                                                        edited(new_text) => {
                                                            root.shell-manage-workspace-edited(key_idx, new_text);
                                                        }
                                                    }

                                                    Rectangle {
                                                        min-width: 88px;
                                                        height: 28px;
                                                        horizontal-stretch: 0;
                                                        border-width: 1px;
                                                        border-color: AppTheme.prompt_chrome_border;
                                                        border-radius: 8px;
                                                        background: #00000000;

                                                        Text {
                                                            text: @tr("選擇資料夾");
                                                            color: AppTheme.text;
                                                            horizontal-alignment: center;
                                                            vertical-alignment: center;
                                                            font-size: 12px;
                                                            font-weight: 600;
                                                        }

                                                        TouchArea {
                                                            clicked => {
                                                                root.shell-manage-workspace-pick-folder(key_idx);
                                                            }
                                                        }
                                                    }
                                                }

                                                Text {
                                                    text: @tr("空白則使用目前工作區（分頁資料夾或啟動目錄）；有填則以該路徑為工作區根目錄。");
                                                    color: AppTheme.text_muted;
                                                    font-size: 10px;
                                                    horizontal-alignment: left;
                                                    wrap: word-wrap;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: root.ws-shell-manage-saved-hint ? @tr("已儲存設定") : "";
                            color: #7fdc9a;
                            font-size: 12px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        Rectangle {
                            min-width: 72px;
                            height: 28px;
                            horizontal-stretch: 0;
                            border-width: 1px;
                            border-color: AppTheme.accent;
                            border-radius: 8px;
                            background: AppTheme.accent;

                            Text {
                                text: @tr("儲存");
                                color: AppTheme.text;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                font-size: 12px;
                                font-weight: 700;
                            }

                            TouchArea {
                                clicked => {
                                    if root.ws-shell-settings-nav == @tr("啟動") {
                                        root.save-shell-startup-settings();
                                    } else if root.ws-shell-settings-nav == @tr("命令提示設定") {
                                        root.save-shell-manage();
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // Edge-only layer so resize cursors stay visible (caption TouchAreas otherwise force Default).
    // Must sit above GjViewer terminal wheel/selection TouchAreas (z≈100–101); below image zoom (450).
    // Winit still handles border drags before Slint mouse handlers; strips are only ~border px wide.
    window-resize-edge-cursors := Rectangle {
        x: 0px;
        y: 0px;
        width: 100%;
        height: 100%;
        background: transparent;
        z: 400;

        property <length> b: AppTheme.chrome_resize_border;
        property <length> title-h: 34px;
        // Caption controls width (must match title strip 3×46px).
        property <length> caption-ctrl-w: 138px;

        TouchArea {
            x: root.width - b;
            y: 0px;
            width: b;
            height: root.height;
            mouse-cursor: e-resize;
        }

        TouchArea {
            x: 0px;
            y: 0px;
            width: b;
            height: root.height;
            mouse-cursor: w-resize;
        }

        TouchArea {
            x: 0px;
            y: root.height - b;
            width: root.width;
            height: b;
            mouse-cursor: s-resize;
        }

        TouchArea {
            x: 0px;
            y: 0px;
            width: root.width - caption-ctrl-w - b;
            height: b;
            mouse-cursor: n-resize;
        }

        TouchArea {
            x: root.width - b;
            y: root.height - b;
            width: b;
            height: b;
            mouse-cursor: se-resize;
        }

        TouchArea {
            x: 0px;
            y: root.height - b;
            width: b;
            height: b;
            mouse-cursor: sw-resize;
        }

        TouchArea {
            x: 0px;
            y: 0px;
            width: b;
            height: b;
            mouse-cursor: nw-resize;
        }
    }

    out property <float> ws-terminal-scroll-top-px: workspace.terminal-scroll-top-px;
    out property <float> ws-terminal-viewport-height-px: workspace.terminal-viewport-height-px;

    if root.ws-image-zoom-index >= 0
            && root.ws-image-zoom-index < root.ws-prompt-images.length: Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #0a0a0fe8;
        z: 450;

        TouchArea {
            width: 100%;
            height: 100%;
            clicked => {
                root.ws-image-zoom-index = -1;
            }

            VerticalLayout {
                alignment: center;
                padding: 24px;
                spacing: 10px;

                Rectangle {
                    width: min(parent.width - 48px, 900px);
                    height: min(parent.height - 80px, 720px);
                    border-width: 1px;
                    border-color: AppTheme.prompt_chrome_border;
                    border-radius: 12px;
                    background: #14161c;
                    clip: true;

                    Image {
                        source: root.ws-prompt-images[root.ws-image-zoom-index].thumb;
                        width: 100%;
                        height: 100%;
                        image-fit: contain;
                    }
                }

                Text {
                    text: @tr("點擊任意處關閉");
                    color: AppTheme.text_muted;
                    font-size: 12px;
                    horizontal-alignment: center;
                }
            }
        }
    }

    if root.ws-file-drop-visible : Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #1a1b26c0; // 半透明背景
        z: 500;

        Rectangle {
            width: 240px;
            height: 120px;
            border-width: 2px;
            border-color: AppTheme.accent;
            border-radius: 12px;
            background: AppTheme.bg;

            VerticalLayout {
                alignment: center;
                spacing: 12px;
                Text {
                    // ASCII "+" — U+2295 (⊕) is often missing from bundled UI fonts and renders as tofu.
                    text: "+";
                    font-size: 32px;
                    font-weight: 300;
                    color: AppTheme.accent;
                    horizontal-alignment: center;
                }
                Text {
                    text: @tr("放開以加入檔案");
                    font-size: 16px;
                    font-weight: 600;
                    color: AppTheme.text;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
